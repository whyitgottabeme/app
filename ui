local Config={}
local CFGDIR="FiberLib"
local function EnsureDir() pcall(function() if not isfolder(CFGDIR) then makefolder(CFGDIR) end end) end
function Config.Save(n,d) local ok=pcall(function() EnsureDir(); writefile(CFGDIR.."/"..n..".json",HttpService:JSONEncode(d)) end); return ok end
function Config.Load(n) local ok,r=pcall(function() return HttpService:JSONDecode(readfile(CFGDIR.."/"..n..".json")) end); return ok and r or nil end
function Config.List() local o={} pcall(function() EnsureDir(); for _,f in ipairs(listfiles(CFGDIR)) do local n=f:match("([^/\\]+)%.json$") if n then table.insert(o,n) end end end); return o end
function Config.Delete(n) pcall(function() delfile(CFGDIR.."/"..n..".json") end) end

