------------------------------------------------------------------------
-- ADD TAB
------------------------------------------------------------------------
function FiberLib:AddTab(name, icon)
    self._tabOrder = self._tabOrder + 1
    local label=(icon and icon.."  " or "")..name
    local btn,bar,lbl=NewTabBtn(self._tabList, label, self._tabOrder)
    local page=NewPage(self._content,name)
    local tabData={name=name,_button=btn,_accentBar=bar,_btnLabel=lbl,_page=page}

    btn.MouseButton1Click:Connect(function() self:_SelectTab(tabData) end)
    btn.MouseEnter:Connect(function() if self._activeTab~=tabData then Tw(btn,{BackgroundTransparency=0.7},0.1) end end)
    btn.MouseLeave:Connect(function() if self._activeTab~=tabData then Tw(btn,{BackgroundTransparency=1},0.1) end end)

    -- Always append; visual order is controlled by LayoutOrder on the button
    table.insert(self._tabs, tabData)

    -- Auto-select the very first user tab added
    local userTabCount=0; for _,td in ipairs(self._tabs) do if td.name~="Settings" then userTabCount=userTabCount+1 end end
    if userTabCount==1 then self:_SelectTab(tabData) end

    local sectionAPI={}

    function sectionAPI:AddSection(title)
        return BuildElements(MakeSectionFrame(title,page))
    end

    function sectionAPI:AddDoubleSection(leftTitle,rightTitle)
        local row=Instance.new("Frame"); row.Name="DoubleSection"; row.BackgroundTransparency=1; row.BorderSizePixel=0
        row.AutomaticSize=Enum.AutomaticSize.Y; row.Size=UDim2.new(1,0,0,0); row.Parent=page
        local rl=Instance.new("UIListLayout"); rl.FillDirection=Enum.FillDirection.Horizontal
        rl.HorizontalAlignment=Enum.HorizontalAlignment.Left; rl.VerticalAlignment=Enum.VerticalAlignment.Top; rl.Padding=UDim.new(0,8); rl.Parent=row

        local function MakeCol(title)
            local col=Instance.new("Frame"); col.BackgroundColor3=Theme.Panel; col.BorderSizePixel=0
            col.AutomaticSize=Enum.AutomaticSize.Y; col.Size=UDim2.new(0.5,-4,0,0); col.Parent=row; Corner(col,8)
            local cs=Stroke(col,Theme.Border,1); T(col,"BackgroundColor3","Panel"); T(cs,"Color","Border")
            local inner=Instance.new("Frame"); inner.BackgroundTransparency=1; inner.Size=UDim2.new(1,0,1,0); inner.AutomaticSize=Enum.AutomaticSize.Y; inner.Parent=col; Pad(inner,8,8,8,8)
            local lay=Instance.new("UIListLayout"); lay.SortOrder=Enum.SortOrder.LayoutOrder; lay.Padding=UDim.new(0,4); lay.Parent=inner
            if title then
                local th=Instance.new("TextLabel"); th.Text=title; th.TextSize=13; th.Font=Enum.Font.GothamBold
                th.TextColor3=Theme.Text; th.BackgroundTransparency=1; th.Size=UDim2.new(1,0,0,20)
                th.TextXAlignment=Enum.TextXAlignment.Center; th.Parent=inner; T(th,"TextColor3","Text")
                local div=Instance.new("Frame"); div.Size=UDim2.new(1,0,0,1); div.BackgroundColor3=Theme.Border; div.BorderSizePixel=0; div.Parent=inner; T(div,"BackgroundColor3","Border")
            end
            return BuildElements(inner)
        end
        return MakeCol(leftTitle), MakeCol(rightTitle)
    end

    return sectionAPI
end

------------------------------------------------------------------------
-- SELECT TAB
------------------------------------------------------------------------
function FiberLib:_SelectTab(tabData)
    if self._activeTab then
        self._activeTab._page.Visible=false
        Tw(self._activeTab._button,{BackgroundTransparency=1},0.15)
        Tw(self._activeTab._btnLabel,{TextColor3=Theme.TextDim},0.15)
        Tw(self._activeTab._accentBar,{BackgroundTransparency=1},0.15)
    end
    self._activeTab=tabData; tabData._page.Visible=true
    Tw(tabData._button,{BackgroundColor3=Theme.PanelAlt,BackgroundTransparency=0},0.15)
    Tw(tabData._btnLabel,{TextColor3=Theme.Text},0.15)
    Tw(tabData._accentBar,{BackgroundTransparency=0},0.15)
end

------------------------------------------------------------------------
-- SETTINGS TAB
------------------------------------------------------------------------
function FiberLib:_BuildSettingsTab()
    local btn,bar,lbl=NewTabBtn(self._tabList,"⚙  Settings", 9999)
    local page=NewPage(self._content,"Settings")
    local tabData={name="Settings",_button=btn,_accentBar=bar,_btnLabel=lbl,_page=page}

    btn.MouseButton1Click:Connect(function() self:_SelectTab(tabData) end)
    btn.MouseEnter:Connect(function() if self._activeTab~=tabData then Tw(btn,{BackgroundTransparency=0.7},0.1) end end)
    btn.MouseLeave:Connect(function() if self._activeTab~=tabData then Tw(btn,{BackgroundTransparency=1},0.1) end end)
    table.insert(self._tabs,tabData)

    -- THEME SECTION
    local themeInner=MakeSectionFrame("Color Theme",page)
    local themeNames={"Default","Black","White","Pink","Grey","Blue","Teal"}
    local swatchColors={Default=Color3.fromRGB(138,43,226),Black=Color3.fromRGB(20,20,20),White=Color3.fromRGB(230,230,235),Pink=Color3.fromRGB(255,105,180),Grey=Color3.fromRGB(140,140,155),Blue=Color3.fromRGB(50,130,255),Teal=Color3.fromRGB(0,210,190)}

    local swatchRow=Instance.new("Frame"); swatchRow.BackgroundTransparency=1; swatchRow.Size=UDim2.new(1,0,0,38); swatchRow.Parent=themeInner
    local srl=Instance.new("UIListLayout"); srl.FillDirection=Enum.FillDirection.Horizontal; srl.HorizontalAlignment=Enum.HorizontalAlignment.Center; srl.Padding=UDim.new(0,7); srl.Parent=swatchRow

    local activeTheme="Default"; local swatches={}
    local activeLabel=Instance.new("TextLabel"); activeLabel.Text="Active: Default"; activeLabel.TextSize=11
    activeLabel.Font=Enum.Font.Gotham; activeLabel.TextColor3=Theme.TextDim; activeLabel.BackgroundTransparency=1
    activeLabel.Size=UDim2.new(1,0,0,16); activeLabel.TextXAlignment=Enum.TextXAlignment.Center
    T(activeLabel,"TextColor3","TextDim")

    for _,tname in ipairs(themeNames) do
        local sw=Instance.new("TextButton"); sw.Size=UDim2.new(0,30,0,30); sw.BackgroundColor3=swatchColors[tname]; sw.Text=""; sw.BorderSizePixel=0; sw.Parent=swatchRow; Corner(sw,99)
        local ring=Instance.new("UIStroke"); ring.Color=Color3.fromRGB(255,255,255); ring.Thickness=tname=="Default" and 2.5 or 0; ring.Parent=sw
        local ck=Instance.new("TextLabel"); ck.Text="✓"; ck.TextSize=13; ck.Font=Enum.Font.GothamBold; ck.TextColor3=Color3.fromRGB(255,255,255); ck.BackgroundTransparency=1; ck.Size=UDim2.new(1,0,1,0); ck.TextXAlignment=Enum.TextXAlignment.Center; ck.Visible=tname=="Default"; ck.Parent=sw
        local tip=Instance.new("TextLabel"); tip.Text=tname; tip.TextSize=10; tip.Font=Enum.Font.Gotham; tip.TextColor3=Color3.fromRGB(255,255,255); tip.BackgroundColor3=Color3.fromRGB(0,0,0); tip.BackgroundTransparency=0.3; tip.Size=UDim2.new(0,55,0,16); tip.Position=UDim2.new(0.5,-27.5,1,5); tip.TextXAlignment=Enum.TextXAlignment.Center; tip.Visible=false; tip.ZIndex=20; tip.Parent=sw; Corner(tip,4)
        sw.MouseEnter:Connect(function() tip.Visible=true end); sw.MouseLeave:Connect(function() tip.Visible=false end)
        sw.MouseButton1Click:Connect(function()
            if swatches[activeTheme] then swatches[activeTheme].ring.Thickness=0; swatches[activeTheme].ck.Visible=false end
            activeTheme=tname; ring.Thickness=2.5; ck.Visible=true; activeLabel.Text="Active: "..tname
            ApplyTheme(tname)
            -- ensure active tab button re-syncs to new Text color
            if self._activeTab then
                Tw(self._activeTab._btnLabel,{TextColor3=Theme.Text},0.15)
                Tw(self._activeTab._button,{BackgroundColor3=Theme.PanelAlt},0.15)
            end
            Config.Save("__theme__",{theme=tname})
        end)
        swatches[tname]={ring=ring,ck=ck}
    end
    activeLabel.Parent=themeInner

    -- KEYBINDS SECTION
    local kbInner=MakeSectionFrame("Keybinds",page)
    local kl=Instance.new("TextLabel"); kl.Text="Left CTRL  —  Toggle UI visibility"; kl.TextSize=12; kl.Font=Enum.Font.Gotham
    kl.TextColor3=Theme.TextDim; kl.BackgroundTransparency=1; kl.Size=UDim2.new(1,0,0,18)
    kl.TextXAlignment=Enum.TextXAlignment.Center; kl.Parent=kbInner; T(kl,"TextColor3","TextDim")

    -- CONFIG SECTION
    local cfgInner=MakeSectionFrame("Config",page)
    local inf=Instance.new("Frame"); inf.Size=UDim2.new(1,0,0,30); inf.BackgroundColor3=Theme.PanelAlt; inf.BorderSizePixel=0; inf.Parent=cfgInner; Corner(inf,5)
    local is=Stroke(inf,Theme.Border,1); T(inf,"BackgroundColor3","PanelAlt"); T(is,"Color","Border")
    local input=Instance.new("TextBox"); input.Size=UDim2.new(1,-12,1,0); input.Position=UDim2.new(0,8,0,0); input.BackgroundTransparency=1
    input.Text=""; input.PlaceholderText="Config name..."; input.TextColor3=Theme.Text; input.PlaceholderColor3=Theme.TextDim
    input.TextSize=12; input.Font=Enum.Font.Gotham; input.TextXAlignment=Enum.TextXAlignment.Left; input.ClearTextOnFocus=false; input.Parent=inf
    T(input,"TextColor3","Text"); T(input,"PlaceholderColor3","TextDim")

    local br=Instance.new("Frame"); br.Size=UDim2.new(1,0,0,28); br.BackgroundTransparency=1; br.Parent=cfgInner
    local brl=Instance.new("UIListLayout"); brl.FillDirection=Enum.FillDirection.Horizontal; brl.Padding=UDim.new(0,6); brl.Parent=br

    local status=Instance.new("TextLabel"); status.Text=""; status.TextSize=11; status.Font=Enum.Font.Gotham
    status.TextColor3=Theme.Accent; status.BackgroundTransparency=1; status.Size=UDim2.new(1,0,0,16)
    status.TextXAlignment=Enum.TextXAlignment.Center; status.Parent=cfgInner; T(status,"TextColor3","Accent")
    local function SetStatus(msg,col) status.Text=msg; status.TextColor3=col or Theme.Accent; task.delay(3,function() if status and status.Parent then status.Text="" end end) end

    local listFrame
    local function CfgBtn(label,cb)
        local b=Instance.new("TextButton"); b.Size=UDim2.new(0.5,-3,1,0); b.BackgroundColor3=Theme.PanelAlt
        b.Text=label; b.TextColor3=Theme.Text; b.TextSize=12; b.Font=Enum.Font.GothamMedium; b.BorderSizePixel=0; b.Parent=br; Corner(b,5)
        local s=Stroke(b,Theme.Border,1); T(b,"BackgroundColor3","PanelAlt"); T(b,"TextColor3","Text"); T(s,"Color","Border")
        b.MouseEnter:Connect(function() Tw(b,{BackgroundColor3=Theme.ButtonHover},0.1) end)
        b.MouseLeave:Connect(function() Tw(b,{BackgroundColor3=Theme.PanelAlt},0.1) end)
        b.MouseButton1Click:Connect(function() Tw(b,{BackgroundColor3=Theme.AccentDim},0.05); task.wait(0.1); Tw(b,{BackgroundColor3=Theme.PanelAlt},0.1); cb() end)
    end

    CfgBtn("💾  Save",function()
        local n=input.Text; if n=="" then SetStatus("⚠ Enter a name",Color3.fromRGB(255,180,0)); return end
        if Config.Save(n,{theme=activeTheme}) then SetStatus("✔ Saved: "..n) else SetStatus("✘ No file access",Color3.fromRGB(255,80,80)) end
        if listFrame then self:_RefreshCfgList(listFrame,input,SetStatus,swatches,activeLabel) end
    end)
    CfgBtn("📂  Load",function()
        local n=input.Text; if n=="" then SetStatus("⚠ Enter a name",Color3.fromRGB(255,180,0)); return end
        local d=Config.Load(n)
        if d then
            if d.theme and Themes[d.theme] then
                if swatches[activeTheme] then swatches[activeTheme].ring.Thickness=0; swatches[activeTheme].ck.Visible=false end
                activeTheme=d.theme; swatches[activeTheme].ring.Thickness=2.5; swatches[activeTheme].ck.Visible=true
                activeLabel.Text="Active: "..d.theme; ApplyTheme(d.theme)
                if self._activeTab then Tw(self._activeTab._btnLabel,{TextColor3=Theme.Text},0.15) end
            end
            SetStatus("✔ Loaded: "..n)
        else SetStatus("✘ Not found",Color3.fromRGB(255,80,80)) end
    end)

    listFrame=Instance.new("Frame"); listFrame.Name="CfgList"; listFrame.BackgroundTransparency=1
    listFrame.AutomaticSize=Enum.AutomaticSize.Y; listFrame.Size=UDim2.new(1,0,0,0); listFrame.Parent=cfgInner
    local lfl=Instance.new("UIListLayout"); lfl.SortOrder=Enum.SortOrder.LayoutOrder; lfl.Padding=UDim.new(0,3); lfl.Parent=listFrame

    self:_RefreshCfgList(listFrame,input,SetStatus,swatches,activeLabel)

    local sv=Config.Load("__theme__")
    if sv and sv.theme and Themes[sv.theme] then
        if swatches[activeTheme] then swatches[activeTheme].ring.Thickness=0; swatches[activeTheme].ck.Visible=false end
        activeTheme=sv.theme; swatches[activeTheme].ring.Thickness=2.5; swatches[activeTheme].ck.Visible=true
        activeLabel.Text="Active: "..sv.theme; ApplyTheme(sv.theme)
    end
end

------------------------------------------------------------------------
-- REFRESH CONFIG LIST
------------------------------------------------------------------------
function FiberLib:_RefreshCfgList(listFrame,inputBox,setStatus,swatches,activeLabel)
    for _,c in ipairs(listFrame:GetChildren()) do if not c:IsA("UIListLayout") then c:Destroy() end end
    local files=Config.List(); local shown={}
    for _,f in ipairs(files) do if f~="__theme__" then table.insert(shown,f) end end
    if #shown==0 then
        local e=Instance.new("TextLabel"); e.Text="No configs saved yet"; e.TextSize=11; e.Font=Enum.Font.Gotham
        e.TextColor3=Theme.TextDisabled; e.BackgroundTransparency=1; e.Size=UDim2.new(1,0,0,16)
        e.TextXAlignment=Enum.TextXAlignment.Center; e.Parent=listFrame; T(e,"TextColor3","TextDisabled"); return
    end
    for _,fname in ipairs(shown) do
        local row=Instance.new("Frame"); row.Size=UDim2.new(1,0,0,26); row.BackgroundColor3=Theme.PanelAlt; row.BorderSizePixel=0; row.Parent=listFrame; Corner(row,5)
        local rs=Stroke(row,Theme.Border,1); T(row,"BackgroundColor3","PanelAlt"); T(rs,"Color","Border")
        local rl=Instance.new("UIListLayout"); rl.FillDirection=Enum.FillDirection.Horizontal; rl.VerticalAlignment=Enum.VerticalAlignment.Center; rl.Padding=UDim.new(0,4); rl.Parent=row; Pad(row,0,0,8,8)
        local nl=Instance.new("TextButton"); nl.Text=fname; nl.TextSize=12; nl.Font=Enum.Font.Gotham; nl.TextColor3=Theme.Text; nl.BackgroundTransparency=1; nl.Size=UDim2.new(1,-52,1,0); nl.TextXAlignment=Enum.TextXAlignment.Left; nl.Parent=row; T(nl,"TextColor3","Text")
        nl.MouseButton1Click:Connect(function() inputBox.Text=fname end)
        local db=Instance.new("TextButton"); db.Text="✕"; db.TextSize=11; db.Font=Enum.Font.GothamBold; db.TextColor3=Color3.fromRGB(200,80,80); db.BackgroundColor3=Theme.Panel; db.Size=UDim2.new(0,22,0,18); db.BorderSizePixel=0; db.Parent=row; Corner(db,4); T(db,"BackgroundColor3","Panel")
        db.MouseButton1Click:Connect(function() Config.Delete(fname); setStatus("🗑 Deleted: "..fname,Color3.fromRGB(255,100,100)); self:_RefreshCfgList(listFrame,inputBox,setStatus,swatches,activeLabel) end)
    end
end

return FiberLib
