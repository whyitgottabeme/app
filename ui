        -- ── SLIDER ────────────────────────────────────────
        function sec:Slider(name, mn, mx, def, callback, suffix)
            suffix = suffix or ""
            mn = mn or 0; mx = mx or 100
            local val = math.clamp(def or mn, mn, mx)
            local pct = (val-mn)/(mx-mn)

            local wrap = new("Frame", {
                BackgroundColor3=TH.Card, Size=UDim2.new(1,0,0,60),
                BorderSizePixel=0, ZIndex=4,
            }, workScroll)
            corner(wrap)
            local wrapStroke = stroke(wrap, TH.Divider, 1)
            pad(wrap, 10, 14, 10, 14)
            reg(wrap, "BackgroundColor3", "Card")
            reg(wrapStroke, "Color", "Divider")

            local topRow = new("Frame", {BackgroundTransparency=1, Size=UDim2.new(1,0,0,20), ZIndex=5}, wrap)

            local nameLbl = new("TextLabel", {
                BackgroundTransparency=1, Size=UDim2.new(0.65,0,1,0),
                Font=Enum.Font.Gotham, Text=name or "",
                TextColor3=TH.TextPrimary, TextSize=14,
                TextXAlignment=Enum.TextXAlignment.Left, ZIndex=5,
            }, topRow)
            reg(nameLbl, "TextColor3", "TextPrimary")

            local valLbl = new("TextLabel", {
                BackgroundTransparency=1,
                Position=UDim2.new(0.65,0,0,0), Size=UDim2.new(0.35,0,1,0),
                Font=Enum.Font.GothamBold, Text=tostring(val)..suffix,
                TextColor3=TH.Accent, TextSize=14,
                TextXAlignment=Enum.TextXAlignment.Right, ZIndex=5,
            }, topRow)
            reg(valLbl, "TextColor3", "Accent")

            local trackBg = new("Frame", {
                BackgroundColor3=TH.Divider,
                Position=UDim2.new(0,0,1,-8), Size=UDim2.new(1,0,0,5),
                BorderSizePixel=0, ZIndex=5,
            }, wrap)
            corner(trackBg, UDim.new(1,0))
            reg(trackBg, "BackgroundColor3", "Divider")

            local fill = new("Frame", {
                BackgroundColor3=TH.Accent,
                Size=UDim2.new(pct,0,1,0), BorderSizePixel=0, ZIndex=6,
            }, trackBg)
            corner(fill, UDim.new(1,0))
            reg(fill, "BackgroundColor3", "Accent")

            local thumbDot = new("Frame", {
                AnchorPoint=Vector2.new(0.5,0.5),
                BackgroundColor3=COL_WHITE,
                Position=UDim2.new(pct,0,0.5,0),
                Size=UDim2.new(0,16,0,16), BorderSizePixel=0, ZIndex=7,
            }, trackBg)
            corner(thumbDot, UDim.new(1,0))
            local thumbStroke = stroke(thumbDot, TH.Accent, 2)
            reg(thumbStroke, "Color", "Accent")

            local dragging = false
            local function update(input)
                local rel = math.clamp(
                    (input.Position.X - trackBg.AbsolutePosition.X) / trackBg.AbsoluteSize.X, 0, 1)
                val = math.floor(mn + (mx-mn)*rel + 0.5)
                fill.Size = UDim2.new(rel,0,1,0)
                thumbDot.Position = UDim2.new(rel,0,0.5,0)
                valLbl.Text = tostring(val)..suffix
                if callback then task.spawn(pcall, callback, val) end
            end
            trackBg.InputBegan:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging=true; update(i) end
            end)
            UserInputService.InputChanged:Connect(function(i)
                if dragging and i.UserInputType == Enum.UserInputType.MouseMovement then update(i) end
            end)
            UserInputService.InputEnded:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging=false end
            end)

            local api = {}
            function api:Set(v)
                v = math.clamp(v, mn, mx); val = v
                local r = (v-mn)/(mx-mn)
                fill.Size = UDim2.new(r,0,1,0)
                thumbDot.Position = UDim2.new(r,0,0.5,0)
                valLbl.Text = tostring(v)..suffix
            end
            function api:Get() return val end
            return api
        end

