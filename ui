        -- ── BUTTON ───────────────────────────────────────
        function sec:Button(name, callback, style)
            -- style: "primary" | "ghost" | "danger"
            style = style or "ghost"

            local bgCol  = TH.OffWhite
            local txtCol = TH.Blue
            local strkCol = TH.Blue

            if style == "primary" then
                bgCol = TH.Blue; txtCol = TH.White; strkCol = TH.Blue
            elseif style == "danger" then
                bgCol = TH.OffWhite; txtCol = TH.Red; strkCol = TH.Red
            end

            local btn = new("TextButton", {
                BackgroundColor3 = bgCol,
                Size             = UDim2.new(1, 0, 0, 38),
                AutoButtonColor  = false,
                Font             = Enum.Font.GothamSemibold,
                Text             = name or "Button",
                TextColor3       = txtCol,
                TextSize         = 14,
                ZIndex           = 4,
            }, workScroll)
            corner(btn)
            if style ~= "primary" then
                stroke(btn, strkCol, 1)
            end

            btn.MouseEnter:Connect(function()
                tween(btn, {BackgroundColor3 = style == "primary" and
                    Color3.fromRGB(10, 85, 220) or TH.BlueLight}, 0.15)
            end)
            btn.MouseLeave:Connect(function()
                tween(btn, {BackgroundColor3 = bgCol}, 0.15)
            end)
            btn.MouseButton1Down:Connect(function()
                tween(btn, {Size = UDim2.new(1, 0, 0, 34)}, 0.08)
            end)
            btn.MouseButton1Up:Connect(function()
                tween(btn, {Size = UDim2.new(1, 0, 0, 38)}, 0.12, Enum.EasingStyle.Back)
            end)
            btn.MouseButton1Click:Connect(function()
                if callback then task.spawn(pcall, callback) end
            end)

            local api = {}
            function api:SetText(t) btn.Text = t end
            return api
        end

        -- ── SWITCH (toggle) ──────────────────────────────
        function sec:Switch(name, default, callback)
            local state = default == true

            local row = new("Frame", {
                BackgroundColor3     = TH.White,
                Size                 = UDim2.new(1, 0, 0, 44),
                BorderSizePixel      = 0,
                ZIndex               = 4,
            }, workScroll)
            corner(row)
            stroke(row, TH.Divider, 1)
            pad(row, 0, 12, 0, 14)

            new("TextLabel", {
                BackgroundTransparency = 1,
                Size                   = UDim2.new(1, -70, 1, 0),
                Font                   = Enum.Font.Gotham,
                Text                   = name or "",
                TextColor3             = TH.TextPrimary,
                TextSize               = 14,
                TextXAlignment         = Enum.TextXAlignment.Left,
                ZIndex                 = 5,
            }, row)

            -- track
            local track = new("Frame", {
                AnchorPoint      = Vector2.new(1, 0.5),
                BackgroundColor3 = state and TH.Blue or TH.Divider,
                Position         = UDim2.new(1, 0, 0.5, 0),
                Size             = UDim2.new(0, 46, 0, 26),
                BorderSizePixel  = 0,
                ZIndex           = 5,
            }, row)
            corner(track, UDim.new(1, 0))

            local thumb = new("Frame", {
                AnchorPoint      = Vector2.new(0.5, 0.5),
                BackgroundColor3 = TH.White,
                Position         = UDim2.new(0, state and 34 or 13, 0.5, 0),
                Size             = UDim2.new(0, 22, 0, 22),
                BorderSizePixel  = 0,
                ZIndex           = 6,
            }, track)
            corner(thumb, UDim.new(1, 0))

            local function setSwitch(val, silent)
                state = val
                tween(track, {BackgroundColor3 = state and TH.Blue or TH.Divider}, 0.18)
                tween(thumb, {Position = UDim2.new(0, state and 34 or 13, 0.5, 0)}, 0.18)
                if not silent and callback then task.spawn(pcall, callback, state) end
            end

            local clickArea = new("TextButton", {
                BackgroundTransparency = 1,
                Size                   = UDim2.new(1, 0, 1, 0),
                Text                   = "",
                ZIndex                 = 7,
            }, row)
            clickArea.MouseButton1Click:Connect(function() setSwitch(not state) end)

            local api = {}
            function api:Set(v)  setSwitch(v, false) end
            function api:Get()   return state end
            return api
        end

        -- ── SLIDER ───────────────────────────────────────
        function sec:Slider(name, min, max, default, callback, suffix)
            suffix = suffix or ""
            min    = min    or 0
            max    = max    or 100
            local val = math.clamp(default or min, min, max)
            local pct = (val - min) / (max - min)

            local wrap = new("Frame", {
                BackgroundColor3 = TH.White,
                Size             = UDim2.new(1, 0, 0, 60),
                BorderSizePixel  = 0,
                ZIndex           = 4,
            }, workScroll)
            corner(wrap)
            stroke(wrap, TH.Divider, 1)
            pad(wrap, 10, 14, 10, 14)

            -- top row: name + value
            local topRow = new("Frame", {
                BackgroundTransparency = 1,
                Size                   = UDim2.new(1, 0, 0, 20),
                ZIndex                 = 5,
            }, wrap)

            new("TextLabel", {
                BackgroundTransparency = 1,
                Size                   = UDim2.new(0.65, 0, 1, 0),
                Font                   = Enum.Font.Gotham,
                Text                   = name or "",
                TextColor3             = TH.TextPrimary,
                TextSize               = 14,
                TextXAlignment         = Enum.TextXAlignment.Left,
                ZIndex                 = 5,
            }, topRow)

            local valLbl = new("TextLabel", {
                BackgroundTransparency = 1,
                Position               = UDim2.new(0.65, 0, 0, 0),
                Size                   = UDim2.new(0.35, 0, 1, 0),
                Font                   = Enum.Font.GothamBold,
                Text                   = tostring(val) .. suffix,
                TextColor3             = TH.Blue,
                TextSize               = 14,
                TextXAlignment         = Enum.TextXAlignment.Right,
                ZIndex                 = 5,
            }, topRow)

            -- track
            local trackBg = new("Frame", {
                BackgroundColor3 = TH.Divider,
                Position         = UDim2.new(0, 0, 1, -8),
                Size             = UDim2.new(1, 0, 0, 5),
                BorderSizePixel  = 0,
                ZIndex           = 5,
            }, wrap)
            corner(trackBg, UDim.new(1, 0))

            local fill = new("Frame", {
                BackgroundColor3 = TH.Blue,
                Size             = UDim2.new(pct, 0, 1, 0),
                BorderSizePixel  = 0,
                ZIndex           = 6,
            }, trackBg)
            corner(fill, UDim.new(1, 0))

            local thumbDot = new("Frame", {
                AnchorPoint      = Vector2.new(0.5, 0.5),
                BackgroundColor3 = TH.White,
                Position         = UDim2.new(pct, 0, 0.5, 0),
                Size             = UDim2.new(0, 16, 0, 16),
                BorderSizePixel  = 0,
                ZIndex           = 7,
            }, trackBg)
            corner(thumbDot, UDim.new(1, 0))
            stroke(thumbDot, TH.Blue, 2)

            local dragging = false
            local function update(input)
                local rel = math.clamp(
                    (input.Position.X - trackBg.AbsolutePosition.X) / trackBg.AbsoluteSize.X, 0, 1)
                val = math.floor(min + (max - min) * rel + 0.5)
                fill.Size          = UDim2.new(rel, 0, 1, 0)
                thumbDot.Position  = UDim2.new(rel, 0, 0.5, 0)
                valLbl.Text        = tostring(val) .. suffix
                if callback then task.spawn(pcall, callback, val) end
            end

            trackBg.InputBegan:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.MouseButton1 then
                    dragging = true; update(i)
                end
            end)
            UserInputService.InputChanged:Connect(function(i)
                if dragging and i.UserInputType == Enum.UserInputType.MouseMovement then
                    update(i)
                end
            end)
            UserInputService.InputEnded:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
            end)

            local api = {}
            function api:Set(v)
                v = math.clamp(v, min, max); val = v
                local r = (v - min) / (max - min)
                fill.Size = UDim2.new(r, 0, 1, 0)
                thumbDot.Position = UDim2.new(r, 0, 0.5, 0)
                valLbl.Text = tostring(v) .. suffix
            end
            function api:Get() return val end
            return api
        end

