function FiberLib:AddTab(name, icon)
    local tabData = {
        name = name,
        sections = {},
        _button = nil,
        _page = nil,
    }

    -- Tab button in sidebar
    local btn = Instance.new("TextButton")
    btn.Name = name
    btn.Size = UDim2.new(1, 0, 0, 30)
    btn.BackgroundColor3 = Theme.Panel
    btn.BackgroundTransparency = 1
    btn.Text = ""
    btn.BorderSizePixel = 0
    btn.Parent = self._tabList
    AddCorner(btn, 6)

    local accentBar = Instance.new("Frame")
    accentBar.Size = UDim2.new(0, 3, 0.6, 0)
    accentBar.Position = UDim2.new(0, 0, 0.2, 0)
    accentBar.BackgroundColor3 = Theme.Accent
    accentBar.BackgroundTransparency = 1
    accentBar.BorderSizePixel = 0
    accentBar.Parent = btn
    AddCorner(accentBar, 99)

    local btnLabel = Instance.new("TextLabel")
    btnLabel.Text = (icon and icon .. "  " or "") .. name
    btnLabel.TextSize = 13
    btnLabel.Font = Enum.Font.GothamMedium
    btnLabel.TextColor3 = Theme.TextDim
    btnLabel.BackgroundTransparency = 1
    btnLabel.Size = UDim2.new(1, -16, 1, 0)
    btnLabel.Position = UDim2.new(0, 12, 0, 0)
    btnLabel.TextXAlignment = Enum.TextXAlignment.Left
    btnLabel.Parent = btn

    -- Tab page (scrollable content)
    local page = Instance.new("ScrollingFrame")
    page.Name = name .. "_Page"
    page.Size = UDim2.new(1, 0, 1, 0)
    page.BackgroundTransparency = 1
    page.BorderSizePixel = 0
    page.ScrollBarThickness = 3
    page.ScrollBarImageColor3 = Theme.Accent
    page.CanvasSize = UDim2.new(0,0,0,0)
    page.AutomaticCanvasSize = Enum.AutomaticSize.Y
    page.Visible = false
    page.Parent = self._content

    local pageLayout = Instance.new("UIListLayout")
    pageLayout.SortOrder = Enum.SortOrder.LayoutOrder
    pageLayout.FillDirection = Enum.FillDirection.Vertical
    pageLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
    pageLayout.Padding = UDim.new(0, 8)
    pageLayout.Parent = page
    AddPadding(page, 8, 8, 8, 8)

    tabData._button = btn
    tabData._btnLabel = btnLabel
    tabData._accentBar = accentBar
    tabData._page = page
    tabData._layout = pageLayout

    -- Switch tab on click
    btn.MouseButton1Click:Connect(function()
        self:_SelectTab(tabData)
    end)

    btn.MouseEnter:Connect(function()
        if self._activeTab ~= tabData then
            Tween(btn, {BackgroundTransparency = 0.7}, 0.1)
        end
    end)
    btn.MouseLeave:Connect(function()
        if self._activeTab ~= tabData then
            Tween(btn, {BackgroundTransparency = 1}, 0.1)
        end
    end)

    table.insert(self._tabs, tabData)

    if #self._tabs == 1 then
        self:_SelectTab(tabData)
    end

    -- Section builder
    local sectionAPI = {}

    function sectionAPI:AddSection(title)
        local sectionFrame = Instance.new("Frame")
        sectionFrame.Name = title or "Section"
        sectionFrame.BackgroundColor3 = Theme.Panel
        sectionFrame.BorderSizePixel = 0
        sectionFrame.AutomaticSize = Enum.AutomaticSize.Y
        sectionFrame.Size = UDim2.new(1, -16, 0, 0)
        sectionFrame.Parent = page
        AddCorner(sectionFrame, 8)
        AddStroke(sectionFrame, Theme.Border, 1)

        local sectionInner = Instance.new("Frame")
        sectionInner.BackgroundTransparency = 1
        sectionInner.Size = UDim2.new(1, 0, 1, 0)
        sectionInner.AutomaticSize = Enum.AutomaticSize.Y
        sectionInner.Parent = sectionFrame
        AddPadding(sectionInner, 8, 8, 8, 8)

        local innerLayout = Instance.new("UIListLayout")
        innerLayout.SortOrder = Enum.SortOrder.LayoutOrder
        innerLayout.Padding = UDim.new(0, 4)
        innerLayout.Parent = sectionInner

        if title then
            local sectionTitle = Instance.new("TextLabel")
            sectionTitle.Text = title
            sectionTitle.TextSize = 13
            sectionTitle.Font = Enum.Font.GothamBold
            sectionTitle.TextColor3 = Theme.Text
            sectionTitle.BackgroundTransparency = 1
            sectionTitle.Size = UDim2.new(1, 0, 0, 20)
            sectionTitle.TextXAlignment = Enum.TextXAlignment.Center
            sectionTitle.Parent = sectionInner

            local titleUnder = Instance.new("Frame")
            titleUnder.Size = UDim2.new(1, 0, 0, 1)
            titleUnder.BackgroundColor3 = Theme.Border
            titleUnder.BorderSizePixel = 0
            titleUnder.Parent = sectionInner
        end

        local elemAPI = {}

        -- TOGGLE
        function elemAPI:AddToggle(label, default, callback)
            local state = default or false

            local row = Instance.new("Frame")
            row.Size = UDim2.new(1, 0, 0, 28)
            row.BackgroundColor3 = Theme.PanelAlt
            row.BorderSizePixel = 0
            row.Parent = sectionInner
            AddCorner(row, 5)

            local rowLabel = Label(row, label, 12, Theme.Text, Enum.Font.Gotham)
            rowLabel.Position = UDim2.new(0, 10, 0.5, -9)
            rowLabel.Size = UDim2.new(1, -48, 0, 18)

            -- Toggle pill
            local pill = Instance.new("Frame")
            pill.Size = UDim2.new(0, 32, 0, 16)
            pill.Position = UDim2.new(1, -42, 0.5, -8)
            pill.BackgroundColor3 = state and Theme.ToggleOn or Theme.ToggleOff
            pill.BorderSizePixel = 0
            pill.Parent = row
            AddCorner(pill, 99)

            local knob = Instance.new("Frame")
            knob.Size = UDim2.new(0, 10, 0, 10)
            knob.Position = state and UDim2.new(1, -13, 0.5, -5) or UDim2.new(0, 3, 0.5, -5)
            knob.BackgroundColor3 = Color3.fromRGB(255,255,255)
            knob.BorderSizePixel = 0
            knob.Parent = pill
            AddCorner(knob, 99)

            local clickArea = Instance.new("TextButton")
            clickArea.Size = UDim2.new(1, 0, 1, 0)
            clickArea.BackgroundTransparency = 1
            clickArea.Text = ""
            clickArea.Parent = row

            clickArea.MouseButton1Click:Connect(function()
                state = not state
                Tween(pill, {BackgroundColor3 = state and Theme.ToggleOn or Theme.ToggleOff}, 0.15)
                Tween(knob, {Position = state and UDim2.new(1,-13,0.5,-5) or UDim2.new(0,3,0.5,-5)}, 0.15)
                if callback then callback(state) end
            end)

            local api = {}
            function api:Set(val)
                state = val
                Tween(pill, {BackgroundColor3 = state and Theme.ToggleOn or Theme.ToggleOff}, 0.15)
                Tween(knob, {Position = state and UDim2.new(1,-13,0.5,-5) or UDim2.new(0,3,0.5,-5)}, 0.15)
            end
            function api:Get() return state end
            return api
        end

        -- BUTTON
        function elemAPI:AddButton(label, callback)
            local btn2 = Instance.new("TextButton")
            btn2.Size = UDim2.new(1, 0, 0, 28)
            btn2.BackgroundColor3 = Theme.PanelAlt
            btn2.Text = label or "Button"
            btn2.TextColor3 = Theme.Text
            btn2.TextSize = 12
            btn2.Font = Enum.Font.GothamMedium
            btn2.BorderSizePixel = 0
            btn2.Parent = sectionInner
            AddCorner(btn2, 5)
            AddStroke(btn2, Theme.Border, 1)

            btn2.MouseEnter:Connect(function()
                Tween(btn2, {BackgroundColor3 = Theme.ButtonHover}, 0.1)
            end)
            btn2.MouseLeave:Connect(function()
                Tween(btn2, {BackgroundColor3 = Theme.PanelAlt}, 0.1)
            end)
            btn2.MouseButton1Click:Connect(function()
                Tween(btn2, {BackgroundColor3 = Theme.AccentDim}, 0.05)
                task.wait(0.1)
                Tween(btn2, {BackgroundColor3 = Theme.PanelAlt}, 0.1)
                if callback then callback() end
            end)

            return btn2
        end

        -- SLIDER
        function elemAPI:AddSlider(label, min, max, default, callback)
            min = min or 0
            max = max or 100
            local value = math.clamp(default or min, min, max)

            local container = Instance.new("Frame")
            container.Size = UDim2.new(1, 0, 0, 40)
            container.BackgroundColor3 = Theme.PanelAlt
            container.BorderSizePixel = 0
            container.Parent = sectionInner
            AddCorner(container, 5)

            local topRow = Instance.new("Frame")
            topRow.Size = UDim2.new(1, -16, 0, 18)
            topRow.Position = UDim2.new(0, 8, 0, 5)
            topRow.BackgroundTransparency = 1
            topRow.Parent = container

            local lbl = Label(topRow, label, 12, Theme.Text, Enum.Font.Gotham)
            lbl.Size = UDim2.new(0.7, 0, 1, 0)

            local valLabel = Label(topRow, tostring(value), 11, Theme.TextDim, Enum.Font.Gotham)
            valLabel.Size = UDim2.new(0.3, 0, 1, 0)
            valLabel.Position = UDim2.new(0.7, 0, 0, 0)
            valLabel.TextXAlignment = Enum.TextXAlignment.Right

            local track = Instance.new("Frame")
            track.Size = UDim2.new(1, -16, 0, 6)
            track.Position = UDim2.new(0, 8, 1, -14)
            track.BackgroundColor3 = Theme.SliderBg
            track.BorderSizePixel = 0
            track.Parent = container
            AddCorner(track, 99)

            local fill = Instance.new("Frame")
            fill.Size = UDim2.new((value - min) / (max - min), 0, 1, 0)
            fill.BackgroundColor3 = Theme.SliderFill
            fill.BorderSizePixel = 0
            fill.Parent = track
            AddCorner(fill, 99)

            local hitbox = Instance.new("TextButton")
            hitbox.Size = UDim2.new(1, 0, 1, 0)
            hitbox.BackgroundTransparency = 1
            hitbox.Text = ""
            hitbox.Parent = track

            local draggingSlider = false
            hitbox.MouseButton1Down:Connect(function()
                draggingSlider = true
            end)
            UserInputService.InputEnded:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.MouseButton1 then
                    draggingSlider = false
                end
            end)
            RunService.RenderStepped:Connect(function()
                if draggingSlider then
                    local pos = UserInputService:GetMouseLocation()
                    local trackPos = track.AbsolutePosition
                    local trackSize = track.AbsoluteSize
                    local rel = math.clamp((pos.X - trackPos.X) / trackSize.X, 0, 1)
                    value = math.floor(min + rel * (max - min))
                    valLabel.Text = tostring(value)
                    Tween(fill, {Size = UDim2.new(rel, 0, 1, 0)}, 0.05)
                    if callback then callback(value) end
                end
            end)

            local api = {}
            function api:Set(v)
                value = math.clamp(v, min, max)
                local rel = (value - min) / (max - min)
                Tween(fill, {Size = UDim2.new(rel, 0, 1, 0)}, 0.1)
                valLabel.Text = tostring(value)
            end
            function api:Get() return value end
            return api
        end

        -- LABEL (info text)
        function elemAPI:AddLabel(text, color)
            local l = Instance.new("TextLabel")
            l.Text = text or ""
            l.TextSize = 11
            l.Font = Enum.Font.Gotham
            l.TextColor3 = color or Theme.TextDim
            l.BackgroundTransparency = 1
            l.Size = UDim2.new(1, 0, 0, 16)
            l.TextXAlignment = Enum.TextXAlignment.Center
            l.Parent = sectionInner
            return l
        end

        -- SEPARATOR
        function elemAPI:AddSeparator()
            local sep = Instance.new("Frame")
            sep.Size = UDim2.new(1, 0, 0, 1)
            sep.BackgroundColor3 = Theme.Border
            sep.BorderSizePixel = 0
            sep.Parent = sectionInner
        end

        -- DROPDOWN
        function elemAPI:AddDropdown(label, options, default, callback)
            local selected = default or (options and options[1]) or ""
            local open = false

            local container = Instance.new("Frame")
            container.Size = UDim2.new(1, 0, 0, 28)
            container.BackgroundColor3 = Theme.PanelAlt
            container.BorderSizePixel = 0
            container.ClipsDescendants = false
            container.Parent = sectionInner
            AddCorner(container, 5)

            local header = Instance.new("TextButton")
            header.Size = UDim2.new(1, 0, 0, 28)
            header.BackgroundTransparency = 1
            header.Text = ""
            header.Parent = container

            local headerLabel = Label(header, label .. ": " .. selected, 12, Theme.Text, Enum.Font.Gotham)
            headerLabel.Position = UDim2.new(0, 10, 0.5, -9)
            headerLabel.Size = UDim2.new(1, -36, 0, 18)

            local arrow = Label(header, "▾", 13, Theme.TextDim, Enum.Font.GothamBold)
            arrow.Position = UDim2.new(1, -22, 0.5, -9)
            arrow.Size = UDim2.new(0, 18, 0, 18)
            arrow.TextXAlignment = Enum.TextXAlignment.Center

            local dropdown = Instance.new("Frame")
            dropdown.Size = UDim2.new(1, 0, 0, 0)
            dropdown.Position = UDim2.new(0, 0, 1, 2)
            dropdown.BackgroundColor3 = Theme.Panel
            dropdown.BorderSizePixel = 0
            dropdown.Visible = false
            dropdown.ZIndex = 10
            dropdown.Parent = container
            AddCorner(dropdown, 6)
            AddStroke(dropdown, Theme.Border, 1)

            local dropLayout = Instance.new("UIListLayout")
            dropLayout.SortOrder = Enum.SortOrder.LayoutOrder
            dropLayout.Parent = dropdown
            AddPadding(dropdown, 4, 4, 4, 4)

            for _, opt in ipairs(options or {}) do
                local optBtn = Instance.new("TextButton")
                optBtn.Size = UDim2.new(1, 0, 0, 24)
                optBtn.BackgroundTransparency = 1
                optBtn.Text = opt
                optBtn.TextColor3 = Theme.TextDim
                optBtn.TextSize = 12
                optBtn.Font = Enum.Font.Gotham
                optBtn.TextXAlignment = Enum.TextXAlignment.Left
                optBtn.ZIndex = 11
                optBtn.Parent = dropdown
                AddPadding(optBtn, 0, 0, 6, 0)

                optBtn.MouseEnter:Connect(function()
                    Tween(optBtn, {TextColor3 = Theme.Text}, 0.1)
                end)
                optBtn.MouseLeave:Connect(function()
                    Tween(optBtn, {TextColor3 = Theme.TextDim}, 0.1)
                end)
                optBtn.MouseButton1Click:Connect(function()
                    selected = opt
                    headerLabel.Text = label .. ": " .. selected
                    open = false
                    dropdown.Visible = false
                    container.Size = UDim2.new(1, 0, 0, 28)
                    if callback then callback(selected) end
                end)
            end

            header.MouseButton1Click:Connect(function()
                open = not open
                dropdown.Visible = open
                local numOpts = #(options or {})
                if open then
                    dropdown.Size = UDim2.new(1, 0, 0, numOpts * 24 + 8)
                    container.Size = UDim2.new(1, 0, 0, 28 + numOpts * 24 + 10)
                else
                    container.Size = UDim2.new(1, 0, 0, 28)
                end
            end)

            local api = {}
            function api:Get() return selected end
            function api:Set(v)
                selected = v
                headerLabel.Text = label .. ": " .. selected
                if callback then callback(selected) end
            end
            return api
        end

        return elemAPI
    end

    return sectionAPI
end

------------------------------------------------------------------------
-- Internal: Select Tab
------------------------------------------------------------------------
function FiberLib:_SelectTab(tabData)
    if self._activeTab then
        self._activeTab._page.Visible = false
        Tween(self._activeTab._button, {BackgroundTransparency = 1}, 0.15)
        Tween(self._activeTab._btnLabel, {TextColor3 = Theme.TextDim}, 0.15)
        Tween(self._activeTab._accentBar, {BackgroundTransparency = 1}, 0.15)
    end
    self._activeTab = tabData
    tabData._page.Visible = true
    Tween(tabData._button, {BackgroundColor3 = Theme.PanelAlt, BackgroundTransparency = 0}, 0.15)
    Tween(tabData._btnLabel, {TextColor3 = Theme.Text}, 0.15)
    Tween(tabData._accentBar, {BackgroundTransparency = 0}, 0.15)
end

return FiberLib
