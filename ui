    -- ── SET THEME ────────────────────────────────────────
    function window:SetTheme(name)
        local t = THEMES[name]
        if not t then return end
        -- update shared TH table
        for k, v in pairs(t) do TH[k] = v end
        -- repaint every registered element
        for _, entry in ipairs(themedObjects) do
            local inst, prop, key = entry[1], entry[2], entry[3]
            if inst and inst.Parent and t[key] then
                pcall(function() tw(inst, {[prop] = t[key]}, 0.25) end)
            end
        end
        -- repaint section tab buttons
        for i, tabBtn in ipairs(sections_list) do
            local isActive = (workareas_list[i] and workareas_list[i].Visible)
            if isActive then
                tabBtn.BackgroundColor3 = t.TabActiveBg
                tabBtn.TextColor3       = t.TabText
            else
                tabBtn.BackgroundColor3 = t.Sidebar
                tabBtn.TextColor3       = t.TextSub
            end
        end
    end

