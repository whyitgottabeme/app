-- Active mutable theme copy
local Theme = {}
for k,v in pairs(Themes.Default) do Theme[k]=v end
Theme.ToggleOn     = Theme.Accent
Theme.SidebarActive= Theme.Accent
Theme.SliderFill   = Theme.Accent

-- Tracked objects for live recolor: {prop, obj, themeKey}
local ThemedObjects = {}
local function Track(obj, prop, key)
    table.insert(ThemedObjects, {obj=obj, prop=prop, key=key})
end

-- Utility: Tween helper
local function Tween(obj, props, duration, style, dir)
    local info = TweenInfo.new(duration or 0.15, style or Enum.EasingStyle.Quad, dir or Enum.EasingDirection.Out)
    TweenService:Create(obj, info, props):Play()
end

-- Utility: Make draggable
local function MakeDraggable(frame, handle)
    handle = handle or frame
    local dragging, dragInput, startPos, startFramePos

    handle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            startPos = input.Position
            startFramePos = frame.Position
        end
    end)

    handle.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - startPos
            frame.Position = UDim2.new(
                startFramePos.X.Scale,
                startFramePos.X.Offset + delta.X,
                startFramePos.Y.Scale,
                startFramePos.Y.Offset + delta.Y
            )
        end
    end)
end

-- Utility: Round corner helper
local function AddCorner(parent, radius)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, radius or 6)
    c.Parent = parent
    return c
end

local function AddPadding(parent, top, bottom, left, right)
    local p = Instance.new("UIPadding")
    p.PaddingTop    = UDim.new(0, top    or 6)
    p.PaddingBottom = UDim.new(0, bottom or 6)
    p.PaddingLeft   = UDim.new(0, left   or 8)
    p.PaddingRight  = UDim.new(0, right  or 8)
    p.Parent = parent
    return p
end

local function AddStroke(parent, color, thickness)
    local s = Instance.new("UIStroke")
    s.Color = color or Theme.Border
    s.Thickness = thickness or 1
    s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    s.Parent = parent
    return s
end

local function Label(parent, text, size, color, weight)
    local l = Instance.new("TextLabel")
    l.Text = text or ""
    l.TextSize = size or 13
    l.TextColor3 = color or Theme.Text
    l.Font = weight or Enum.Font.GothamMedium
    l.BackgroundTransparency = 1
    l.TextXAlignment = Enum.TextXAlignment.Left
    l.Size = UDim2.new(1, 0, 0, size and size + 4 or 18)
    l.Parent = parent
    return l
end

------------------------------------------------------------------------
-- APPLY THEME (live recolor all tracked objects)
------------------------------------------------------------------------
local function ApplyTheme(themeName)
    local t = Themes[themeName]
    if not t then return end
    for k,v in pairs(t) do Theme[k]=v end
    Theme.ToggleOn      = Theme.Accent
    Theme.SidebarActive = Theme.Accent
    Theme.SliderFill    = Theme.Accent
    for _, entry in ipairs(ThemedObjects) do
        pcall(function()
            local color = Theme[entry.key]
            if color then
                TweenService:Create(entry.obj, TweenInfo.new(0.25, Enum.EasingStyle.Quad), {[entry.prop]=color}):Play()
            end
        end)
    end
end

------------------------------------------------------------------------
-- CONFIG SYSTEM
------------------------------------------------------------------------
local ConfigSystem = {}
local CONFIG_FOLDER = "FiberLib"

local function EnsureFolder()
    pcall(function()
        if not isfolder(CONFIG_FOLDER) then makefolder(CONFIG_FOLDER) end
    end)
end

function ConfigSystem.Save(name, data)
    local ok = pcall(function()
        EnsureFolder()
        writefile(CONFIG_FOLDER.."/"..name..".json",
            game:GetService("HttpService"):JSONEncode(data))
    end)
    return ok
end

function ConfigSystem.Load(name)
    local ok, result = pcall(function()
        return game:GetService("HttpService"):JSONDecode(
            readfile(CONFIG_FOLDER.."/"..name..".json"))
    end)
    return ok and result or nil
end

function ConfigSystem.List()
    local files = {}
    pcall(function()
        EnsureFolder()
        for _, f in ipairs(listfiles(CONFIG_FOLDER)) do
            local n = f:match("([^/\\]+)%.json$")
            if n then table.insert(files, n) end
        end
    end)
    return files
end

function ConfigSystem.Delete(name)
    pcall(function() delfile(CONFIG_FOLDER.."/"..name..".json") end)
end

