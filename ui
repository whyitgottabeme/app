------------------------------------------------------------------------
-- Internal: Select Tab
------------------------------------------------------------------------
function FiberLib:_SelectTab(tabData)
    if self._activeTab then
        self._activeTab._page.Visible = false
        TweenService:Create(self._activeTab._button, TweenInfo.new(0.15), {BackgroundTransparency=1}):Play()
        TweenService:Create(self._activeTab._btnLabel, TweenInfo.new(0.15), {TextColor3=Theme.TextDim}):Play()
        TweenService:Create(self._activeTab._accentBar, TweenInfo.new(0.15), {BackgroundTransparency=1}):Play()
    end
    self._activeTab = tabData
    tabData._page.Visible = true
    TweenService:Create(tabData._button, TweenInfo.new(0.15), {BackgroundColor3=Theme.PanelAlt, BackgroundTransparency=0}):Play()
    TweenService:Create(tabData._btnLabel, TweenInfo.new(0.15), {TextColor3=Theme.Text}):Play()
    TweenService:Create(tabData._accentBar, TweenInfo.new(0.15), {BackgroundTransparency=0}):Play()
end

