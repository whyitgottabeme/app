        -- ── DROPDOWN ─────────────────────────────────────
        function sec:Dropdown(name, options, callback)
            options = options or {}
            local selected = options[1] or "Select…"
            local open     = false

            local wrap = new("Frame", {
                BackgroundColor3     = TH.White,
                Size                 = UDim2.new(1, 0, 0, 44),
                BorderSizePixel      = 0,
                ClipsDescendants     = false,
                ZIndex               = 4,
            }, workScroll)
            corner(wrap)
            stroke(wrap, TH.Divider, 1)
            pad(wrap, 0, 12, 0, 14)

            new("TextLabel", {
                BackgroundTransparency = 1,
                Size                   = UDim2.new(0.45, 0, 1, 0),
                Font                   = Enum.Font.Gotham,
                Text                   = name or "",
                TextColor3             = TH.TextPrimary,
                TextSize               = 14,
                TextXAlignment         = Enum.TextXAlignment.Left,
                ZIndex                 = 5,
            }, wrap)

            local selLabel = new("TextLabel", {
                AnchorPoint          = Vector2.new(1, 0.5),
                BackgroundTransparency = 1,
                Position             = UDim2.new(1, -20, 0.5, 0),
                Size                 = UDim2.new(0.5, -24, 0, 20),
                Font                 = Enum.Font.GothamSemibold,
                Text                 = selected,
                TextColor3           = TH.Blue,
                TextSize             = 13,
                TextXAlignment       = Enum.TextXAlignment.Right,
                ZIndex               = 5,
            }, wrap)

            local chevron = new("TextLabel", {
                AnchorPoint          = Vector2.new(1, 0.5),
                BackgroundTransparency = 1,
                Position             = UDim2.new(1, 0, 0.5, 0),
                Size                 = UDim2.new(0, 16, 0, 20),
                Font                 = Enum.Font.GothamBold,
                Text                 = "›",
                TextColor3           = TH.TextMuted,
                TextSize             = 18,
                Rotation             = 90,
                ZIndex               = 5,
            }, wrap)

            -- dropdown list panel
            local panel = new("Frame", {
                BackgroundColor3 = TH.White,
                BorderSizePixel  = 0,
                Position         = UDim2.new(0, 0, 1, 4),
                Size             = UDim2.new(1, 0, 0, 0),
                ClipsDescendants = true,
                ZIndex           = 12,
                Visible          = false,
            }, wrap)
            corner(panel)
            stroke(panel, TH.Divider, 1)

            local pInner = new("Frame", {
                BackgroundTransparency = 1,
                Size                   = UDim2.new(1, 0, 0, 0),
                ZIndex                 = 13,
            }, panel)
            pcall(function() pInner.AutomaticSize = Enum.AutomaticSize.Y end)
            pad(pInner, 4, 4, 4, 4)
            local pLayout = list(pInner, Enum.FillDirection.Vertical, 2)

            local function closeDD()
                open = false
                tween(chevron, {Rotation = 90}, 0.18)
                tween(panel, {Size = UDim2.new(1, 0, 0, 0)}, 0.18)
                task.delay(0.2, function() panel.Visible = false end)
                wrap.Size = UDim2.new(1, 0, 0, 44)
            end

            local function openDD()
                open = true
                panel.Visible = true
                tween(chevron, {Rotation = 270}, 0.18)
                local h = pLayout.AbsoluteContentSize.Y + 8
                tween(panel, {Size = UDim2.new(1, 0, 0, h)}, 0.2)
                wrap.Size = UDim2.new(1, 0, 0, 44 + h + 4)
            end

            for _, opt in ipairs(options) do
                local item = new("TextButton", {
                    BackgroundColor3     = TH.OffWhite,
                    BackgroundTransparency = 1,
                    Size                 = UDim2.new(1, 0, 0, 30),
                    AutoButtonColor      = false,
                    Font                 = Enum.Font.Gotham,
                    Text                 = opt,
                    TextColor3           = TH.TextSub,
                    TextSize             = 13,
                    TextXAlignment       = Enum.TextXAlignment.Left,
                    ZIndex               = 14,
                }, pInner)
                corner(item, UDim.new(0, 5))
                pad(item, 0, 8, 0, 10)

                item.MouseEnter:Connect(function()
                    tween(item, {BackgroundTransparency = 0.7, TextColor3 = TH.Blue}, 0.1)
                end)
                item.MouseLeave:Connect(function()
                    tween(item, {BackgroundTransparency = 1, TextColor3 = TH.TextSub}, 0.1)
                end)
                item.MouseButton1Click:Connect(function()
                    selected = opt
                    selLabel.Text = opt
                    closeDD()
                    if callback then task.spawn(pcall, callback, opt) end
                end)
            end

            local hBtn = new("TextButton", {
                BackgroundTransparency = 1,
                Size = UDim2.new(1, 0, 1, 0), Text = "", ZIndex = 6,
            }, wrap)
            hBtn.MouseButton1Click:Connect(function()
                if open then closeDD() else openDD() end
            end)

            local api = {}
            function api:Get() return selected end
            function api:Set(v) selected = v; selLabel.Text = v end
            return api
        end

        -- ── KEYBIND ──────────────────────────────────────
        function sec:Keybind(name, default, callback)
            local key       = default or Enum.KeyCode.RightShift
            local listening = false

            local row = new("Frame", {
                BackgroundColor3 = TH.White,
                Size             = UDim2.new(1, 0, 0, 44),
                BorderSizePixel  = 0,
                ZIndex           = 4,
            }, workScroll)
            corner(row)
            stroke(row, TH.Divider, 1)
            pad(row, 0, 12, 0, 14)

            new("TextLabel", {
                BackgroundTransparency = 1,
                Size                   = UDim2.new(0.6, 0, 1, 0),
                Font                   = Enum.Font.Gotham,
                Text                   = name or "",
                TextColor3             = TH.TextPrimary,
                TextSize               = 14,
                TextXAlignment         = Enum.TextXAlignment.Left,
                ZIndex                 = 5,
            }, row)

            local badge = new("TextButton", {
                AnchorPoint      = Vector2.new(1, 0.5),
                BackgroundColor3 = TH.OffWhite,
                Position         = UDim2.new(1, 0, 0.5, 0),
                Size             = UDim2.new(0, 90, 0, 26),
                AutoButtonColor  = false,
                Font             = Enum.Font.GothamSemibold,
                Text             = key.Name,
                TextColor3       = TH.TextSub,
                TextSize         = 12,
                ZIndex           = 5,
            }, row)
            pcall(function() badge.AutomaticSize = Enum.AutomaticSize.X end)
            pad(badge, 0, 10, 0, 10)
            corner(badge, UDim.new(0, 5))
            stroke(badge, TH.Divider, 1)

            badge.MouseButton1Click:Connect(function()
                if listening then return end
                listening     = true
                badge.Text    = "…"
                badge.TextColor3 = TH.Yellow
                local conn
                conn = UserInputService.InputBegan:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.Keyboard then
                        key              = input.KeyCode
                        badge.Text       = key.Name
                        badge.TextColor3 = TH.TextSub
                        listening        = false
                        conn:Disconnect()
                        if callback then task.spawn(pcall, callback, key) end
                    end
                end)
            end)

            -- fire callback on press
            UserInputService.InputBegan:Connect(function(input, gp)
                if not gp and not listening and input.KeyCode == key and callback then
                    task.spawn(pcall, callback, key)
                end
            end)

            local api = {}
            function api:Get() return key end
            function api:Set(k) key = k; badge.Text = k.Name end
            return api
        end

        return sec
    end -- window:Section

    -- animate window open
    tween(main, {Position = UDim2.new(0.5, 0, 0.5, 0)}, 0.6, Enum.EasingStyle.Back)

    return window
end -- lib:init

return lib
