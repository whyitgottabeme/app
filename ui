                Position=UDim2.new(1,-20,0.5,0), Size=UDim2.new(0.5,-24,0,20),
                Font=Enum.Font.GothamSemibold, Text=selected,
                TextColor3=TH.Accent, TextSize=13,
                TextXAlignment=Enum.TextXAlignment.Right, ZIndex=5,
            }, wrap)
            reg(selLbl, "TextColor3", "Accent")

            local chevron = new("TextLabel", {
                AnchorPoint=Vector2.new(1,0.5), BackgroundTransparency=1,
                Position=UDim2.new(1,0,0.5,0), Size=UDim2.new(0,16,0,20),
                Font=Enum.Font.GothamBold, Text="›",
                TextColor3=TH.TextMuted, TextSize=18, Rotation=90, ZIndex=5,
            }, wrap)
            reg(chevron, "TextColor3", "TextMuted")

            -- floating panel parented to rightPanel — never clipped by workScroll
            local panel = new("Frame", {
                BackgroundColor3=TH.Card, BorderSizePixel=0,
                Position=UDim2.new(0,0,0,0), -- repositioned in openDD
                Size=UDim2.new(0,0,0,0),
                ClipsDescendants=true, ZIndex=20, Visible=false,
            }, rightPanel)
            corner(panel)
            local panelStroke = stroke(panel, TH.Divider, 1)
            reg(panel, "BackgroundColor3", "Card")
            reg(panelStroke, "Color", "Divider")

            local pInner = new("Frame", {
                BackgroundTransparency=1, Size=UDim2.new(1,0,0,0), ZIndex=21,
            }, panel)
            pcall(function() pInner.AutomaticSize = Enum.AutomaticSize.Y end)
            pad(pInner, 4, 4, 4, 4)
            local pLayout = listLayout(pInner, Enum.FillDirection.Vertical, 2)

            -- compute panel position relative to rightPanel using AbsolutePosition
            local function repositionPanel()
                local wAbs  = wrap.AbsolutePosition
                local rpAbs = rightPanel.AbsolutePosition
                local wSz   = wrap.AbsoluteSize
                local relX  = wAbs.X - rpAbs.X
                local relY  = wAbs.Y - rpAbs.Y + wSz.Y + 4
                panel.Position = UDim2.new(0, relX, 0, relY)
                panel.Size     = UDim2.new(0, wSz.X, 0, panel.Size.Y.Offset)
            end

            local function closeDD()
                open = false
                tw(chevron, {Rotation=90}, 0.18)
                tw(panel, {Size=UDim2.new(0, panel.Size.X.Offset, 0, 0)}, 0.18)
                task.delay(0.2, function() panel.Visible = false end)
            end

            local function openDD()
                open = true
                repositionPanel()
                panel.Visible = true
                tw(chevron, {Rotation=270}, 0.18)
                -- wait one frame so AbsoluteContentSize is valid
                task.defer(function()
                    local h = pLayout.AbsoluteContentSize.Y + 8
                    local wSz = wrap.AbsoluteSize
                    panel.Size = UDim2.new(0, wSz.X, 0, 0)
                    tw(panel, {Size=UDim2.new(0, wSz.X, 0, h)}, 0.2)
                end)
            end

            for _, opt in ipairs(options) do
                local item = new("TextButton", {
                    BackgroundColor3=TH.Card, BackgroundTransparency=1,
                    Size=UDim2.new(1,0,0,32), AutoButtonColor=false,
                    Font=Enum.Font.Gotham, Text=opt,
                    TextColor3=TH.TextSub, TextSize=13,
                    TextXAlignment=Enum.TextXAlignment.Left, ZIndex=22,
                }, pInner)
                corner(item, UDim.new(0,5))
                pad(item, 0, 10, 0, 10)
                item.MouseEnter:Connect(function()
                    tw(item, {BackgroundTransparency=0.7, TextColor3=TH.Accent}, 0.1)
                end)
                item.MouseLeave:Connect(function()
                    tw(item, {BackgroundTransparency=1, TextColor3=TH.TextSub}, 0.1)
                end)
                item.MouseButton1Click:Connect(function()
                    selected = opt; selLbl.Text = opt
                    closeDD()
                    if callback then task.spawn(pcall, callback, opt) end
                end)
            end

            local hBtn = new("TextButton", {
                BackgroundTransparency=1, Size=UDim2.new(1,0,1,0), Text="", ZIndex=6,
            }, wrap)
            hBtn.MouseButton1Click:Connect(function()
                if open then closeDD() else openDD() end
            end)
            -- hide the click-catcher when open so panel items receive input
            local _origClose = closeDD
            local _origOpen  = openDD
            closeDD = function()
                _origClose()
                hBtn.Visible = true
            end
            openDD = function()
                hBtn.Visible = false
                _origOpen()
            end

            -- close if user clicks anywhere else
            UserInputService.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 and open then
                    task.defer(function()
                        -- check if click was inside the panel
                        local mp = UserInputService:GetMouseLocation()
                        local pp = panel.AbsolutePosition
                        local ps = panel.AbsoluteSize
                        local wp = wrap.AbsolutePosition
                        local ws = wrap.AbsoluteSize
                        local inPanel = mp.X >= pp.X and mp.X <= pp.X+ps.X and mp.Y >= pp.Y and mp.Y <= pp.Y+ps.Y
                        local inWrap  = mp.X >= wp.X and mp.X <= wp.X+ws.X and mp.Y >= wp.Y and mp.Y <= wp.Y+ws.Y
                        if not inPanel and not inWrap then closeDD() end
                    end)
                end
            end)

            local api = {}
            function api:Get() return selected end
            function api:Set(v) selected=v; selLbl.Text=v end
            return api
        end

        -- ── KEYBIND ───────────────────────────────────────
        function sec:Keybind(name, default, callback)
            local key = default or Enum.KeyCode.RightShift
            local listening = false
            local row = new("Frame", {
                BackgroundColor3=TH.Card, Size=UDim2.new(1,0,0,44),
                BorderSizePixel=0, ZIndex=4,
            }, workScroll)
            corner(row)
            local rowStroke = stroke(row, TH.Divider, 1)
            pad(row, 0, 12, 0, 14)
            reg(row, "BackgroundColor3", "Card")
            reg(rowStroke, "Color", "Divider")

            local nameLbl = new("TextLabel", {
                BackgroundTransparency=1, Size=UDim2.new(0.6,0,1,0),
                Font=Enum.Font.Gotham, Text=name or "",
                TextColor3=TH.TextPrimary, TextSize=14,
                TextXAlignment=Enum.TextXAlignment.Left, ZIndex=5,
            }, row)
            reg(nameLbl, "TextColor3", "TextPrimary")

            local badge = new("TextButton", {
                AnchorPoint=Vector2.new(1,0.5),
                BackgroundColor3=TH.Input,
                Position=UDim2.new(1,0,0.5,0), Size=UDim2.new(0,90,0,26),
                AutoButtonColor=false, Font=Enum.Font.GothamSemibold,
                Text=key.Name, TextColor3=TH.TextSub, TextSize=12, ZIndex=5,
            }, row)
            pcall(function() badge.AutomaticSize = Enum.AutomaticSize.X end)
            pad(badge, 0, 10, 0, 10)
            corner(badge, UDim.new(0,5))
            local badgeStroke = stroke(badge, TH.Divider, 1)
            reg(badge, "BackgroundColor3", "Input")
            reg(badge, "TextColor3", "TextSub")
            reg(badgeStroke, "Color", "Divider")

            badge.MouseButton1Click:Connect(function()
                if listening then return end
                listening = true; badge.Text = "…"; badge.TextColor3 = COL_YELLOW
                local conn
                conn = UserInputService.InputBegan:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.Keyboard then
                        key = input.KeyCode
                        badge.Text = key.Name; badge.TextColor3 = TH.TextSub
                        listening = false; conn:Disconnect()
                        if callback then task.spawn(pcall, callback, key) end
                    end
                end)
            end)
            UserInputService.InputBegan:Connect(function(input, gp)
                if not gp and not listening and input.KeyCode == key and callback then
                    task.spawn(pcall, callback, key)
                end
            end)
            row.MouseEnter:Connect(function() tw(row, {BackgroundColor3=TH.CardHover}, 0.12) end)
            row.MouseLeave:Connect(function() tw(row, {BackgroundColor3=TH.Card}, 0.12) end)

            local api = {}
            function api:Get() return key end
            function api:Set(k) key=k; badge.Text=k.Name end
            return api
        end

        return sec
    end -- window:Section

    -- ── ANIMATE OPEN ─────────────────────────────────────
    tw(main, {Position=UDim2.new(0.5,0,0.5,0)}, 0.6, Enum.EasingStyle.Back)

    -- ── PATCH SetTheme to also fix switches correctly ────
    -- override to handle the custom function entries we added
    local _originalSetTheme = window.SetTheme
    function window:SetTheme(name)
        local t = THEMES[name]
        if not t then return end
        -- mutate TH in place so all live closures (hover, etc.) see new values
        for k, v in pairs(t) do TH[k] = v end
        -- repaint all registered static elements
        for _, entry in ipairs(themedObjects) do
            local inst, prop, key, fn = entry[1], entry[2], entry[3], entry[4]
            if fn then
                pcall(fn, t)
            elseif inst and inst.Parent and prop and key and t[key] then
                pcall(function() tw(inst, {[prop]=t[key]}, 0.25) end)
            end
        end
        -- repaint structural frames not in registry
        tw(main,        {BackgroundColor3 = t.Main},    0.25)
        tw(topbar,      {BackgroundColor3 = t.Topbar},  0.25)
        tw(leftPanel,   {BackgroundColor3 = t.Sidebar}, 0.25)
        tw(rightPanel,  {BackgroundColor3 = t.Main},    0.25)
        tw(searchFrame, {BackgroundColor3 = t.Input},   0.25)
        tw(topbarBorder,{BackgroundColor3 = t.Divider}, 0.25)
        tw(leftBorder,  {BackgroundColor3 = t.Divider}, 0.25)
        tw(n1btn,       {BackgroundColor3 = t.Accent},  0.25)
        tw(n2btn1,      {BackgroundColor3 = t.Accent},  0.25)
        tw(n2btn2,      {BackgroundColor3 = t.Card},    0.25)
        tw(n2btn2,      {TextColor3       = t.Accent},  0.25)
        tw(titleLabel,  {TextColor3       = t.TextPrimary}, 0.25)
        tw(sectionTitle,{TextColor3       = t.TextMuted},   0.25)
        tw(searchBox,   {TextColor3       = t.TextPrimary}, 0.25)
        pcall(function() sideScroll.ScrollBarImageColor3 = t.Divider end)
        pcall(function() searchBox.PlaceholderColor3     = t.TextMuted end)
        -- repaint all work area scrolls
        for _, ws in ipairs(workareas_list) do
            tw(ws, {BackgroundColor3 = t.Main}, 0.25)
        end
        -- repaint sidebar tab buttons
        for i, btn in ipairs(sections_list) do
            local isActive = workareas_list[i] and workareas_list[i].Visible
            if isActive then
                tw(btn, {BackgroundColor3=t.TabActiveBg, TextColor3=t.TabText}, 0.25)
                btn.BackgroundTransparency = 0
            else
                btn.BackgroundTransparency = 1
                tw(btn, {TextColor3=t.TextSub}, 0.25)
            end
        end
    end

    return window
end -- lib:init

return lib
