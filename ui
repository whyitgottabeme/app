-- Live mutable theme copy
local Theme = {}
for k,v in pairs(Themes.Default) do Theme[k]=v end
Theme.ToggleOn=Theme.Accent; Theme.SidebarActive=Theme.Accent; Theme.SliderFill=Theme.Accent

-- Tracker: every UI object registers here for live recoloring
-- { obj, prop, key }  — key is a field name in Theme
local Tracked = {}
local function T(obj, prop, key) table.insert(Tracked,{obj=obj,prop=prop,key=key}) end

local function ApplyTheme(name)
    local t=Themes[name]; if not t then return end
    for k,v in pairs(t) do Theme[k]=v end
    Theme.ToggleOn=Theme.Accent; Theme.SidebarActive=Theme.Accent; Theme.SliderFill=Theme.Accent
    local tw=TweenInfo.new(0.25,Enum.EasingStyle.Quad)
    for _,e in ipairs(Tracked) do
        pcall(function()
            local c=Theme[e.key]; if c then TweenService:Create(e.obj,tw,{[e.prop]=c}):Play() end
        end)
    end
end

