        -- ── SWITCH (toggle) ───────────────────────────────
        function sec:Switch(name, default, callback)
            local state = default == true
            local row = new("Frame", {
                BackgroundColor3=TH.Card, Size=UDim2.new(1,0,0,44),
                BorderSizePixel=0, ZIndex=4,
            }, workScroll)
            corner(row)
            local rowStroke = stroke(row, TH.Divider, 1)
            pad(row, 0, 12, 0, 14)
            reg(row, "BackgroundColor3", "Card")
            reg(rowStroke, "Color", "Divider")

            local nameLbl = new("TextLabel", {
                BackgroundTransparency=1, Size=UDim2.new(1,-70,1,0),
                Font=Enum.Font.Gotham, Text=name or "",
                TextColor3=TH.TextPrimary, TextSize=14,
                TextXAlignment=Enum.TextXAlignment.Left, ZIndex=5,
            }, row)
            reg(nameLbl, "TextColor3", "TextPrimary")

            local track = new("Frame", {
                AnchorPoint=Vector2.new(1,0.5),
                BackgroundColor3=state and TH.SwitchOn or TH.SwitchOff,
                Position=UDim2.new(1,0,0.5,0), Size=UDim2.new(0,46,0,26),
                BorderSizePixel=0, ZIndex=5,
            }, row)
            corner(track, UDim.new(1,0))

            local thumb = new("Frame", {
                AnchorPoint=Vector2.new(0.5,0.5),
                BackgroundColor3=COL_WHITE,
                Position=UDim2.new(0,state and 34 or 13,0.5,0),
                Size=UDim2.new(0,22,0,22), BorderSizePixel=0, ZIndex=6,
            }, track)
            corner(thumb, UDim.new(1,0))

            -- register track for both states via a custom approach
            local function setSwitch(val, silent)
                state = val
                tw(track, {BackgroundColor3 = state and TH.SwitchOn or TH.SwitchOff}, 0.18)
                tw(thumb, {Position = UDim2.new(0, state and 34 or 13, 0.5, 0)}, 0.18)
                if not silent and callback then task.spawn(pcall, callback, state) end
            end

            -- re-register track colour when theme changes
            -- we handle this in a custom registry entry via a function hook
            table.insert(themedObjects, {nil, nil, nil, function(t)
                track.BackgroundColor3 = state and t.SwitchOn or t.SwitchOff
            end})

            local click = new("TextButton", {
                BackgroundTransparency=1, Size=UDim2.new(1,0,1,0), Text="", ZIndex=7,
            }, row)
            click.MouseButton1Click:Connect(function() setSwitch(not state) end)

            row.MouseEnter:Connect(function() tw(row, {BackgroundColor3=TH.CardHover}, 0.12) end)
            row.MouseLeave:Connect(function() tw(row, {BackgroundColor3=TH.Card}, 0.12) end)

            local api = {}
            function api:Set(v) setSwitch(v, false) end
            function api:Get() return state end
            return api
        end

