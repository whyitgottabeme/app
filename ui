local function MakeSectionFrame(title, parent)
    local sf=Instance.new("Frame"); sf.Name=title or "Section"; sf.BackgroundColor3=Theme.Panel
    sf.BorderSizePixel=0; sf.AutomaticSize=Enum.AutomaticSize.Y; sf.Size=UDim2.new(1,0,0,0); sf.Parent=parent
    Corner(sf,8); local ss=Stroke(sf,Theme.Border,1); T(sf,"BackgroundColor3","Panel"); T(ss,"Color","Border")
    local inner=Instance.new("Frame"); inner.BackgroundTransparency=1; inner.Size=UDim2.new(1,0,1,0)
    inner.AutomaticSize=Enum.AutomaticSize.Y; inner.Parent=sf; Pad(inner,8,8,8,8)
    local lay=Instance.new("UIListLayout"); lay.SortOrder=Enum.SortOrder.LayoutOrder; lay.Padding=UDim.new(0,4); lay.Parent=inner
    if title then
        local th=Instance.new("TextLabel"); th.Text=title; th.TextSize=13; th.Font=Enum.Font.GothamBold
        th.TextColor3=Theme.Text; th.BackgroundTransparency=1; th.Size=UDim2.new(1,0,0,20)
        th.TextXAlignment=Enum.TextXAlignment.Center; th.Parent=inner; T(th,"TextColor3","Text")
        local div=Instance.new("Frame"); div.Size=UDim2.new(1,0,0,1); div.BackgroundColor3=Theme.Border
        div.BorderSizePixel=0; div.Parent=inner; T(div,"BackgroundColor3","Border")
    end
    return inner
end

------------------------------------------------------------------------
-- ELEMENT BUILDERS  — T() on every single visual property
------------------------------------------------------------------------
local function BuildElements(sectionInner)
    local api={}

    -- TOGGLE
    function api:AddToggle(label,default,callback)
        local state=default or false
        local row=Instance.new("Frame"); row.Size=UDim2.new(1,0,0,28); row.BackgroundColor3=Theme.PanelAlt
        row.BorderSizePixel=0; row.Parent=sectionInner; Corner(row,5)
        local rs=Stroke(row,Theme.Border,1); T(row,"BackgroundColor3","PanelAlt"); T(rs,"Color","Border")
        local rl=Instance.new("TextLabel"); rl.Text=label; rl.TextSize=12; rl.Font=Enum.Font.Gotham
        rl.TextColor3=Theme.Text; rl.BackgroundTransparency=1; rl.Size=UDim2.new(1,-48,0,18)
        rl.Position=UDim2.new(0,10,0.5,-9); rl.TextXAlignment=Enum.TextXAlignment.Left; rl.Parent=row; T(rl,"TextColor3","Text")
        local pill=Instance.new("Frame"); pill.Size=UDim2.new(0,32,0,16); pill.Position=UDim2.new(1,-42,0.5,-8)
        pill.BackgroundColor3=state and Theme.ToggleOn or Theme.ToggleOff; pill.BorderSizePixel=0; pill.Parent=row; Corner(pill,99)
        local knob=Instance.new("Frame"); knob.Size=UDim2.new(0,10,0,10)
        knob.Position=state and UDim2.new(1,-13,0.5,-5) or UDim2.new(0,3,0.5,-5)
        knob.BackgroundColor3=Color3.fromRGB(255,255,255); knob.BorderSizePixel=0; knob.Parent=pill; Corner(knob,99)
        -- Dynamic tracking for pill (state-dependent)
        local pillEntry={obj=pill,prop="BackgroundColor3",key=state and "ToggleOn" or "ToggleOff"}
        table.insert(Tracked,pillEntry)
        local hit=Instance.new("TextButton"); hit.Size=UDim2.new(1,0,1,0); hit.BackgroundTransparency=1; hit.Text=""; hit.Parent=row
        hit.MouseButton1Click:Connect(function()
            state=not state; pillEntry.key=state and "ToggleOn" or "ToggleOff"
            Tw(pill,{BackgroundColor3=state and Theme.ToggleOn or Theme.ToggleOff},0.15)
            Tw(knob,{Position=state and UDim2.new(1,-13,0.5,-5) or UDim2.new(0,3,0.5,-5)},0.15)
            if callback then callback(state) end
        end)
        local tapi={}
        function tapi:Set(v) state=v; pillEntry.key=state and "ToggleOn" or "ToggleOff"; Tw(pill,{BackgroundColor3=state and Theme.ToggleOn or Theme.ToggleOff},0.15); Tw(knob,{Position=state and UDim2.new(1,-13,0.5,-5) or UDim2.new(0,3,0.5,-5)},0.15) end
        function tapi:Get() return state end
        return tapi
    end

    -- BUTTON
    function api:AddButton(label,callback)
        local b=Instance.new("TextButton"); b.Size=UDim2.new(1,0,0,28); b.BackgroundColor3=Theme.PanelAlt
        b.Text=label or "Button"; b.TextColor3=Theme.Text; b.TextSize=12; b.Font=Enum.Font.GothamMedium
        b.BorderSizePixel=0; b.Parent=sectionInner; Corner(b,5)
        local s=Stroke(b,Theme.Border,1); T(b,"BackgroundColor3","PanelAlt"); T(b,"TextColor3","Text"); T(s,"Color","Border")
        b.MouseEnter:Connect(function() Tw(b,{BackgroundColor3=Theme.ButtonHover},0.1) end)
        b.MouseLeave:Connect(function() Tw(b,{BackgroundColor3=Theme.PanelAlt},0.1) end)
        b.MouseButton1Click:Connect(function() Tw(b,{BackgroundColor3=Theme.AccentDim},0.05); task.wait(0.1); Tw(b,{BackgroundColor3=Theme.PanelAlt},0.1); if callback then callback() end end)
        return b
    end

    -- SLIDER
    function api:AddSlider(label,min,max,default,callback)
        min=min or 0; max=max or 100; local value=math.clamp(default or min,min,max)
        local c=Instance.new("Frame"); c.Size=UDim2.new(1,0,0,40); c.BackgroundColor3=Theme.PanelAlt
        c.BorderSizePixel=0; c.Parent=sectionInner; Corner(c,5); T(c,"BackgroundColor3","PanelAlt")
        local top=Instance.new("Frame"); top.Size=UDim2.new(1,-16,0,18); top.Position=UDim2.new(0,8,0,5); top.BackgroundTransparency=1; top.Parent=c
        local ll=Lbl(top,label,12,Theme.Text,Enum.Font.Gotham); ll.Size=UDim2.new(0.7,0,1,0); T(ll,"TextColor3","Text")
        local vl=Lbl(top,tostring(value),11,Theme.TextDim,Enum.Font.Gotham); vl.Size=UDim2.new(0.3,0,1,0); vl.Position=UDim2.new(0.7,0,0,0); vl.TextXAlignment=Enum.TextXAlignment.Right; T(vl,"TextColor3","TextDim")
        local track=Instance.new("Frame"); track.Size=UDim2.new(1,-16,0,6); track.Position=UDim2.new(0,8,1,-14); track.BackgroundColor3=Theme.SliderBg; track.BorderSizePixel=0; track.Parent=c; Corner(track,99); T(track,"BackgroundColor3","SliderBg")
        local fill=Instance.new("Frame"); fill.Size=UDim2.new((value-min)/(max-min),0,1,0); fill.BackgroundColor3=Theme.Accent; fill.BorderSizePixel=0; fill.Parent=track; Corner(fill,99); T(fill,"BackgroundColor3","Accent")
        local hit=Instance.new("TextButton"); hit.Size=UDim2.new(1,0,1,0); hit.BackgroundTransparency=1; hit.Text=""; hit.Parent=track
        local dragging=false
        hit.MouseButton1Down:Connect(function() dragging=true end)
        UserInputService.InputEnded:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then dragging=false end end)
        RunService.RenderStepped:Connect(function()
            if dragging then
                local rel=math.clamp((UserInputService:GetMouseLocation().X-track.AbsolutePosition.X)/track.AbsoluteSize.X,0,1)
                value=math.floor(min+rel*(max-min)); vl.Text=tostring(value); Tw(fill,{Size=UDim2.new(rel,0,1,0)},0.05); if callback then callback(value) end
            end
        end)
        local sapi={}; function sapi:Set(v) value=math.clamp(v,min,max); local r=(value-min)/(max-min); Tw(fill,{Size=UDim2.new(r,0,1,0)},0.1); vl.Text=tostring(value) end; function sapi:Get() return value end; return sapi
    end

    -- LABEL
    function api:AddLabel(text,color)
        local l=Instance.new("TextLabel"); l.Text=text or ""; l.TextSize=11; l.Font=Enum.Font.Gotham
        l.TextColor3=color or Theme.TextDim; l.BackgroundTransparency=1; l.Size=UDim2.new(1,0,0,16)
        l.TextXAlignment=Enum.TextXAlignment.Center; l.Parent=sectionInner; T(l,"TextColor3","TextDim"); return l
    end

    -- SEPARATOR
    function api:AddSeparator()
        local s=Instance.new("Frame"); s.Size=UDim2.new(1,0,0,1); s.BackgroundColor3=Theme.Border; s.BorderSizePixel=0; s.Parent=sectionInner; T(s,"BackgroundColor3","Border")
    end

    -- DROPDOWN
    function api:AddDropdown(label,options,default,callback)
        local selected=default or (options and options[1]) or ""; local open=false
        local cont=Instance.new("Frame"); cont.Size=UDim2.new(1,0,0,28); cont.BackgroundColor3=Theme.PanelAlt
        cont.BorderSizePixel=0; cont.ClipsDescendants=false; cont.Parent=sectionInner; Corner(cont,5)
        local cs=Stroke(cont,Theme.Border,1); T(cont,"BackgroundColor3","PanelAlt"); T(cs,"Color","Border")
        local hdr=Instance.new("TextButton"); hdr.Size=UDim2.new(1,0,0,28); hdr.BackgroundTransparency=1; hdr.Text=""; hdr.Parent=cont
        local hl=Lbl(hdr,label..": "..selected,12,Theme.Text,Enum.Font.Gotham); hl.Position=UDim2.new(0,10,0.5,-9); hl.Size=UDim2.new(1,-36,0,18); T(hl,"TextColor3","Text")
        local ar=Lbl(hdr,"▾",13,Theme.TextDim,Enum.Font.GothamBold); ar.Position=UDim2.new(1,-22,0.5,-9); ar.Size=UDim2.new(0,18,0,18); ar.TextXAlignment=Enum.TextXAlignment.Center; T(ar,"TextColor3","TextDim")
        local dd=Instance.new("Frame"); dd.Size=UDim2.new(1,0,0,0); dd.Position=UDim2.new(0,0,1,2); dd.BackgroundColor3=Theme.Panel; dd.BorderSizePixel=0; dd.Visible=false; dd.ZIndex=10; dd.Parent=cont; Corner(dd,6)
        local ds=Stroke(dd,Theme.Border,1); T(dd,"BackgroundColor3","Panel"); T(ds,"Color","Border")
        local dl=Instance.new("UIListLayout"); dl.SortOrder=Enum.SortOrder.LayoutOrder; dl.Parent=dd; Pad(dd,4,4,4,4)
        for _,opt in ipairs(options or {}) do
            local ob=Instance.new("TextButton"); ob.Size=UDim2.new(1,0,0,24); ob.BackgroundTransparency=1
            ob.Text=opt; ob.TextColor3=Theme.TextDim; ob.TextSize=12; ob.Font=Enum.Font.Gotham
            ob.TextXAlignment=Enum.TextXAlignment.Left; ob.ZIndex=11; ob.Parent=dd; Pad(ob,0,0,6,0); T(ob,"TextColor3","TextDim")
            ob.MouseEnter:Connect(function() Tw(ob,{TextColor3=Theme.Text},0.1) end)
            ob.MouseLeave:Connect(function() Tw(ob,{TextColor3=Theme.TextDim},0.1) end)
            ob.MouseButton1Click:Connect(function() selected=opt; hl.Text=label..": "..selected; open=false; dd.Visible=false; cont.Size=UDim2.new(1,0,0,28); if callback then callback(selected) end end)
        end
        hdr.MouseButton1Click:Connect(function() open=not open; dd.Visible=open; local n=#(options or {}); if open then dd.Size=UDim2.new(1,0,0,n*24+8); cont.Size=UDim2.new(1,0,0,28+n*24+10) else cont.Size=UDim2.new(1,0,0,28) end end)
        local dapi={}; function dapi:Get() return selected end; function dapi:Set(v) selected=v; hl.Text=label..": "..selected; if callback then callback(selected) end end; return dapi
    end

    return api
end

