        Grey    = Color3.fromRGB(140,140,155),
        Blue    = Color3.fromRGB(50,130,255),
        Teal    = Color3.fromRGB(0,210,190),
    }

    -- Grid of color swatches
    local swatchRow = Instance.new("Frame")
    swatchRow.BackgroundTransparency = 1
    swatchRow.Size = UDim2.new(1,0,0,36)
    swatchRow.Parent = themeInner

    local swatchLayout = Instance.new("UIListLayout")
    swatchLayout.FillDirection = Enum.FillDirection.Horizontal
    swatchLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
    swatchLayout.Padding = UDim.new(0,6)
    swatchLayout.Parent = swatchRow

    local activeThemeName = "Default"
    local swatches = {}

    for _, tname in ipairs(themeNames) do
        local sw = Instance.new("TextButton")
        sw.Size = UDim2.new(0, 28, 0, 28)
        sw.BackgroundColor3 = themeColors[tname]
        sw.Text = ""
        sw.BorderSizePixel = 0
        sw.Parent = swatchRow
        AddCorner(sw, 99)

        -- White ring for selected
        local ring = Instance.new("UIStroke")
        ring.Color = Color3.fromRGB(255,255,255)
        ring.Thickness = tname == "Default" and 2 or 0
        ring.Parent = sw

        local tooltip = Instance.new("TextLabel")
        tooltip.Text = tname
        tooltip.TextSize = 10
        tooltip.Font = Enum.Font.Gotham
        tooltip.TextColor3 = Color3.fromRGB(255,255,255)
        tooltip.BackgroundColor3 = Color3.fromRGB(0,0,0)
        tooltip.BackgroundTransparency = 0.3
        tooltip.Size = UDim2.new(0,50,0,16)
        tooltip.Position = UDim2.new(0.5,-25,1,4)
        tooltip.TextXAlignment = Enum.TextXAlignment.Center
        tooltip.Visible = false
        tooltip.ZIndex = 20
        tooltip.Parent = sw
        AddCorner(tooltip, 4)

        sw.MouseEnter:Connect(function() tooltip.Visible = true end)
        sw.MouseLeave:Connect(function() tooltip.Visible = false end)

        sw.MouseButton1Click:Connect(function()
            -- Remove ring from old
            if swatches[activeThemeName] then
                swatches[activeThemeName].ring.Thickness = 0
            end
            activeThemeName = tname
            ring.Thickness = 2
            ApplyTheme(tname)
            -- save theme to config
            ConfigSystem.Save("__theme__", {theme=tname})
        end)

        swatches[tname] = {btn=sw, ring=ring}
    end

    -- Active theme label
    local themeLabel = Instance.new("TextLabel")
    themeLabel.Text = "Active: Default"
    themeLabel.TextSize = 11
    themeLabel.Font = Enum.Font.Gotham
    themeLabel.TextColor3 = Theme.TextDim
    themeLabel.BackgroundTransparency = 1
    themeLabel.Size = UDim2.new(1,0,0,16)
    themeLabel.TextXAlignment = Enum.TextXAlignment.Center
    themeLabel.Parent = themeInner
    Track(themeLabel, "TextColor3", "TextDim")

    -- Update label when theme changes
    local origApply = ApplyTheme
    local self_ref = self
    -- Patch: wrap ApplyTheme to also update label
    -- (We do this by connecting inside; ApplyTheme is already defined globally)
    for _, tname in ipairs(themeNames) do
        swatches[tname].btn.MouseButton1Click:Connect(function()
            themeLabel.Text = "Active: "..tname
        end)
    end

    -- =================== KEYBIND INFO ===================
    local keybindInner = MakeSection("Keybinds")

    local kbInfo = Instance.new("TextLabel")
    kbInfo.Text = "Left CTRL — Toggle UI visibility"
    kbInfo.TextSize = 12
    kbInfo.Font = Enum.Font.Gotham
    kbInfo.TextColor3 = Theme.TextDim
    kbInfo.BackgroundTransparency = 1
    kbInfo.Size = UDim2.new(1,0,0,18)
    kbInfo.TextXAlignment = Enum.TextXAlignment.Center
    kbInfo.Parent = keybindInner
    Track(kbInfo, "TextColor3", "TextDim")

    -- =================== CONFIG SECTION ===================
    local configInner = MakeSection("Config")

    -- Config name input (TextBox)
    local inputFrame = Instance.new("Frame")
    inputFrame.Size = UDim2.new(1,0,0,30)
    inputFrame.BackgroundColor3 = Theme.PanelAlt
    inputFrame.BorderSizePixel = 0
    inputFrame.Parent = configInner
    AddCorner(inputFrame, 5)
    AddStroke(inputFrame, Theme.Border, 1)
    Track(inputFrame, "BackgroundColor3", "PanelAlt")

    local configInput = Instance.new("TextBox")
    configInput.Size = UDim2.new(1,-12,1,0)
    configInput.Position = UDim2.new(0,8,0,0)
    configInput.BackgroundTransparency = 1
    configInput.Text = ""
    configInput.PlaceholderText = "Config name..."
    configInput.TextColor3 = Theme.Text
    configInput.PlaceholderColor3 = Theme.TextDim
    configInput.TextSize = 12
    configInput.Font = Enum.Font.Gotham
    configInput.TextXAlignment = Enum.TextXAlignment.Left
    configInput.ClearTextOnFocus = false
    configInput.Parent = inputFrame
    Track(configInput, "TextColor3", "Text")

    -- Save / Load buttons side by side
    local btnRow = Instance.new("Frame")
    btnRow.Size = UDim2.new(1,0,0,28)
    btnRow.BackgroundTransparency = 1
    btnRow.Parent = configInner

    local btnRowLayout = Instance.new("UIListLayout")
    btnRowLayout.FillDirection = Enum.FillDirection.Horizontal
    btnRowLayout.Padding = UDim.new(0,6)
    btnRowLayout.Parent = btnRow

    local function ConfigBtn(label, callback)
        local b = Instance.new("TextButton")
        b.Size = UDim2.new(0.5,-3,1,0)
        b.BackgroundColor3 = Theme.PanelAlt
        b.Text = label
        b.TextColor3 = Theme.Text
        b.TextSize = 12
        b.Font = Enum.Font.GothamMedium
        b.BorderSizePixel = 0
        b.Parent = btnRow
        AddCorner(b, 5)
        AddStroke(b, Theme.Border, 1)
        Track(b, "BackgroundColor3", "PanelAlt")
        Track(b, "TextColor3", "Text")
        b.MouseEnter:Connect(function()
            TweenService:Create(b,TweenInfo.new(0.1),{BackgroundColor3=Theme.ButtonHover}):Play()
        end)
        b.MouseLeave:Connect(function()
            TweenService:Create(b,TweenInfo.new(0.1),{BackgroundColor3=Theme.PanelAlt}):Play()
        end)
        b.MouseButton1Click:Connect(function()
            TweenService:Create(b,TweenInfo.new(0.05),{BackgroundColor3=Theme.AccentDim}):Play()
            task.wait(0.1)
            TweenService:Create(b,TweenInfo.new(0.1),{BackgroundColor3=Theme.PanelAlt}):Play()
            callback()
        end)
        return b
    end

    -- Status label
    local statusLabel = Instance.new("TextLabel")
    statusLabel.Text = ""
    statusLabel.TextSize = 11
    statusLabel.Font = Enum.Font.Gotham
    statusLabel.TextColor3 = Theme.Accent
    statusLabel.BackgroundTransparency = 1
    statusLabel.Size = UDim2.new(1,0,0,16)
    statusLabel.TextXAlignment = Enum.TextXAlignment.Center
    statusLabel.Parent = configInner
    Track(statusLabel, "TextColor3", "Accent")

    local function SetStatus(msg, color)
        statusLabel.Text = msg
        statusLabel.TextColor3 = color or Theme.Accent
        task.delay(3, function() statusLabel.Text = "" end)
    end

    ConfigBtn("💾  Save", function()
        local name = configInput.Text
        if name == "" then SetStatus("⚠ Enter a config name", Color3.fromRGB(255,180,0)) return end
        local data = { theme = activeThemeName }
        -- Let user extend via self.Config.SaveData
        if self._configData then
            for k,v in pairs(self._configData) do data[k]=v end
        end
        if ConfigSystem.Save(name, data) then
            SetStatus("✔ Saved: "..name)
            self:_RefreshConfigList(configListFrame, configInput, SetStatus, swatches, themeLabel)
        else
            SetStatus("✘ Save failed (no file access)", Color3.fromRGB(255,80,80))
        end
    end)

    ConfigBtn("📂  Load", function()
        local name = configInput.Text
        if name == "" then SetStatus("⚠ Enter a config name", Color3.fromRGB(255,180,0)) return end
        local data = ConfigSystem.Load(name)
        if data then
            if data.theme and Themes[data.theme] then
                -- deselect old swatch
                if swatches[activeThemeName] then swatches[activeThemeName].ring.Thickness=0 end
                activeThemeName = data.theme
                swatches[activeThemeName].ring.Thickness = 2
                ApplyTheme(data.theme)
                themeLabel.Text = "Active: "..data.theme
            end
            SetStatus("✔ Loaded: "..name)
        else
            SetStatus("✘ Config not found", Color3.fromRGB(255,80,80))
        end
    end)

    -- Config list
    local configListFrame = Instance.new("Frame")
    configListFrame.Name = "ConfigList"
    configListFrame.BackgroundTransparency = 1
    configListFrame.AutomaticSize = Enum.AutomaticSize.Y
    configListFrame.Size = UDim2.new(1,0,0,0)
    configListFrame.Parent = configInner

    local configListLayout = Instance.new("UIListLayout")
    configListLayout.SortOrder = Enum.SortOrder.LayoutOrder
    configListLayout.Padding = UDim.new(0,3)
    configListLayout.Parent = configListFrame

    self._configListFrame = configListFrame
    self:_RefreshConfigList(configListFrame, configInput, SetStatus, swatches, themeLabel)

    -- Load saved theme on startup
    local savedTheme = ConfigSystem.Load("__theme__")
    if savedTheme and savedTheme.theme and Themes[savedTheme.theme] then
        if swatches[activeThemeName] then swatches[activeThemeName].ring.Thickness=0 end
        activeThemeName = savedTheme.theme
        swatches[activeThemeName].ring.Thickness = 2
        ApplyTheme(savedTheme.theme)
        themeLabel.Text = "Active: "..savedTheme.theme
    end
end

------------------------------------------------------------------------
-- Internal: Refresh config file list UI
------------------------------------------------------------------------
function FiberLib:_RefreshConfigList(listFrame, inputBox, setStatus, swatches, themeLabel)
    -- clear old entries
    for _, c in ipairs(listFrame:GetChildren()) do
        if not c:IsA("UIListLayout") then c:Destroy() end
    end

    local files = ConfigSystem.List()
    if #files == 0 then
        local empty = Instance.new("TextLabel")
        empty.Text = "No configs saved yet"
        empty.TextSize = 11
        empty.Font = Enum.Font.Gotham
        empty.TextColor3 = Theme.TextDisabled
        empty.BackgroundTransparency = 1
        empty.Size = UDim2.new(1,0,0,16)
        empty.TextXAlignment = Enum.TextXAlignment.Center
        empty.Parent = listFrame
        Track(empty, "TextColor3", "TextDisabled")
        return
    end

    for _, fname in ipairs(files) do
        if fname ~= "__theme__" then
            local row = Instance.new("Frame")
            row.Size = UDim2.new(1,0,0,26)
            row.BackgroundColor3 = Theme.PanelAlt
            row.BorderSizePixel = 0
            row.Parent = listFrame
            AddCorner(row, 5)
            Track(row, "BackgroundColor3", "PanelAlt")

            local rowLayout = Instance.new("UIListLayout")
            rowLayout.FillDirection = Enum.FillDirection.Horizontal
            rowLayout.VerticalAlignment = Enum.VerticalAlignment.Center
            rowLayout.Padding = UDim.new(0,4)
            rowLayout.Parent = row
            AddPadding(row, 0, 0, 8, 8)

            local nameLbl = Instance.new("TextButton")
            nameLbl.Text = fname
            nameLbl.TextSize = 12
            nameLbl.Font = Enum.Font.Gotham
            nameLbl.TextColor3 = Theme.Text
            nameLbl.BackgroundTransparency = 1
            nameLbl.Size = UDim2.new(1,-52,1,0)
            nameLbl.TextXAlignment = Enum.TextXAlignment.Left
            nameLbl.Parent = row
            Track(nameLbl, "TextColor3", "Text")
            nameLbl.MouseButton1Click:Connect(function()
                inputBox.Text = fname
            end)

            local delBtn = Instance.new("TextButton")
            delBtn.Text = "✕"
            delBtn.TextSize = 11
            delBtn.Font = Enum.Font.GothamBold
            delBtn.TextColor3 = Color3.fromRGB(200,80,80)
            delBtn.BackgroundColor3 = Theme.Panel
            delBtn.Size = UDim2.new(0,22,0,18)
            delBtn.BorderSizePixel = 0
            delBtn.Parent = row
            AddCorner(delBtn, 4)
            Track(delBtn, "BackgroundColor3", "Panel")
            delBtn.MouseButton1Click:Connect(function()
                ConfigSystem.Delete(fname)
                setStatus("🗑 Deleted: "..fname, Color3.fromRGB(255,100,100))
                self:_RefreshConfigList(listFrame, inputBox, setStatus, swatches, themeLabel)
            end)
        end
    end
end

return FiberLib
